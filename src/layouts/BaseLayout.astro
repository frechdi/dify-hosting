---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
interface Props {
  title: string; description: string; lang: string;
  canonical?: string; ogImage?: string; schema?: object | object[];
  noindex?: boolean; keywords?: string; hreflang?: { lang: string; url: string }[];
}
const { title, description, lang, canonical, ogImage='/images/og-dify-hosting.webp', schema, noindex=false, keywords, hreflang=[] } = Astro.props;
const site = 'https://dify-hosting.com';
const canonicalUrl = canonical || `${site}${Astro.url.pathname}`;
const schemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const allSchemas = [
  { '@context':'https://schema.org','@type':'Organization',name:'Dify Hosting',url:site,logo:`${site}/logos/dify-logo.svg`,sameAs:['https://github.com/langgenius/dify'] },
  { '@context':'https://schema.org','@type':'WebSite',url:site,name:'Dify Hosting',inLanguage:lang },
  ...schemas
];
const localeMap: Record<string,string> = {en:'en_US',de:'de_DE',fr:'fr_FR',es:'es_ES',it:'it_IT'};
---
<!DOCTYPE html>
<html lang={lang} dir="ltr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  {keywords && <meta name="keywords" content={keywords}/>}
  <link rel="canonical" href={canonicalUrl}/>
  {noindex ? <meta name="robots" content="noindex,nofollow"/> : <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large"/>}
  {hreflang.map(h=><link rel="alternate" hreflang={h.lang} href={h.url}/>)}
  <link rel="alternate" hreflang="x-default" href={`${site}/en${Astro.url.pathname.replace(/^\/(en|de|fr|es|it)/,'')||'/'}`}/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content={canonicalUrl}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={`${site}${ogImage}`}/>
  <meta property="og:locale" content={localeMap[lang]||'en_US'}/>
  <meta property="og:site_name" content="Dify Hosting"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image" content={`${site}${ogImage}`}/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..900;1,14..32,300..900&display=swap" rel="stylesheet"/>
  {allSchemas.map(s=><script type="application/ld+json" set:html={JSON.stringify(s)}/>)}
</head>
<body>
  <Header lang={lang}/>
  <main style="padding-top:64px;"><slot/></main>
  <Footer lang={lang}/>
  <CookieBanner lang={lang}/>
  <script>
    // FAQ accordion: auto-detect FAQ sections by h2 text and make cards collapsible
    const faqKeywords = ['faq','frequently','häufig','fréquent','preguntas','domande frequenti','sık sorulan'];
    document.querySelectorAll('section').forEach(section => {
      const h2 = section.querySelector('h2');
      if (!h2) return;
      const h2text = h2.textContent.toLowerCase();
      if (!faqKeywords.some(k => h2text.includes(k))) return;
      section.querySelectorAll('.card').forEach(card => {
        const h3 = card.querySelector('h3');
        const p = card.querySelector('p');
        if (!h3 || !p) return;
        // Hide answer initially
        p.style.display = 'none';
        p.style.marginTop = '0.6rem';
        // Style question as clickable
        h3.style.cssText += ';cursor:pointer;display:flex;justify-content:space-between;align-items:center;margin-bottom:0;user-select:none;';
        const chevron = document.createElement('span');
        chevron.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 5l5 5 5-5"/></svg>';
        chevron.style.cssText = 'flex-shrink:0;margin-left:0.75rem;opacity:0.5;transition:transform 0.2s;';
        h3.appendChild(chevron);
        h3.addEventListener('click', () => {
          const isOpen = p.style.display !== 'none';
          p.style.display = isOpen ? 'none' : 'block';
          chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
          chevron.style.opacity = isOpen ? '0.5' : '1';
        });
      });
    });
  </script>
</body>
</html>
