---
interface Props { lang: string; }
const { lang } = Astro.props;
const messages: Record<string, { text: string; accept: string; decline: string }> = {
  en: { text: 'We use cookies to improve your experience and analyze traffic. By clicking "Accept", you consent to our use of cookies.', accept: 'Accept All', decline: 'Decline' },
  de: { text: 'Wir verwenden Cookies, um Ihre Erfahrung zu verbessern und den Traffic zu analysieren. Mit "Akzeptieren" stimmen Sie unserer Cookie-Nutzung zu.', accept: 'Alle akzeptieren', decline: 'Ablehnen' },
  fr: { text: 'Nous utilisons des cookies pour améliorer votre expérience. En cliquant "Accepter", vous consentez à notre utilisation des cookies.', accept: 'Tout accepter', decline: 'Refuser' },
  es: { text: 'Usamos cookies para mejorar tu experiencia. Al hacer clic en "Aceptar", consientes el uso de cookies.', accept: 'Aceptar todo', decline: 'Rechazar' },
  it: { text: 'Utilizziamo i cookie per migliorare la tua esperienza. Cliccando "Accetta", acconsenti all\'uso dei cookie.', accept: 'Accetta tutto', decline: 'Rifiuta' },
};
const m = messages[lang] || messages.en;
---

<div id="cookie-banner" style="display:none;position:fixed;bottom:1.5rem;left:1.5rem;right:1.5rem;max-width:600px;margin:0 auto;background:hsl(240 6% 10%);border:1px solid hsl(240 4% 22%);border-radius:1rem;padding:1.25rem 1.5rem;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,0.5);">
  <p style="color:hsl(0 0% 80%);font-size:0.85rem;line-height:1.6;margin-bottom:1rem;">{m.text}</p>
  <div style="display:flex;gap:0.75rem;">
    <button id="cookie-accept" class="btn-primary" style="padding:0.5rem 1.25rem;font-size:0.85rem;">{m.accept}</button>
    <button id="cookie-decline" class="btn-secondary" style="padding:0.5rem 1.25rem;font-size:0.85rem;">{m.decline}</button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const consent = localStorage.getItem('cookie-consent');
  if (!consent) banner!.style.display = 'block';
  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'accepted');
    banner!.style.display = 'none';
  });
  document.getElementById('cookie-decline')?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'declined');
    banner!.style.display = 'none';
  });
</script>
