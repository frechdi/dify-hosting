---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../../i18n/hreflang';

const hreflang = getHreflang('/guides/dify-agent/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Dify KI-Agenten Anleitung 2026: Autonome KI mit Tools bauen',
  description: 'Vollständige Anleitung zu Dify KI-Agenten. Baue autonome KI, die im Web sucht, Code ausführt, APIs aufruft und mehrstufige Aufgaben erledigt — ohne Programmierkenntnisse.',
  datePublished: '2026-01-01',
  dateModified: '2026-03-24',
  author: { '@type': 'Organization', name: 'Dify Hosting' },
};
---

<BaseLayout
  title="Dify KI-Agenten Anleitung 2026: Autonome KI mit Tools bauen"
  description="Vollständige Anleitung zu Dify KI-Agenten. Baue autonome KI, die im Web sucht, Code ausführt, APIs aufruft und mehrstufige Aufgaben erledigt — ohne Programmierkenntnisse."
  lang="de"
  canonical="https://dify-hosting.com/de/guides/dify-agent/"
  hreflang={hreflang}
  schema={[schema, {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Was können Dify KI-Agenten tun?","acceptedAnswer":{"@type":"Answer","text":"Dify KI-Agenten können im Web suchen (Google, Bing, DuckDuckGo), Python-Code ausführen, externe APIs aufrufen, Wikipedia lesen, Mathematik berechnen, Wetter prüfen und vieles mehr. Sie entscheiden selbstständig, welche Tools sie für jede Aufgabe verwenden."}},{"@type":"Question","name":"Was ist der Unterschied zwischen einem Dify Agent und einem Chatbot?","acceptedAnswer":{"@type":"Answer","text":"Ein Dify Chatbot beantwortet Fragen basierend auf seinem Training und deinen Prompts. Ein Dify Agent verwendet aktiv Tools — er kann das Internet durchsuchen, Code ausführen oder APIs aufrufen. Nutze Chatbots für Support, Agenten für Recherche und Automatisierung."}},{"@type":"Question","name":"Kann ich einem Dify Agenten eigene Tools hinzufügen?","acceptedAnswer":{"@type":"Answer","text":"Ja. Du kannst jede REST-API als Custom Tool hinzufügen, indem du eine OpenAPI-Spezifikation oder manuell Endpunkt, Name, Beschreibung und Parameter angibst. Der Agent nutzt dein Tool, wenn die Aufgabe es erfordert."}},{"@type":"Question","name":"Unterstützt Dify Agent mehrstufiges Reasoning?","acceptedAnswer":{"@type":"Answer","text":"Ja. Dify Agenten nutzen ReAct (Reasoning + Acting) oder Function Calling. Der Agent denkt Schritt für Schritt, ruft Tools auf, beobachtet Ergebnisse und fährt fort, bis die Aufgabe abgeschlossen ist — ähnlich wie AutoGPT oder LangChain."}}]}]}
>
  <!-- Hero -->
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Startseite', href: '/de/' },
        { label: 'Guides', href: '/de/guides/' },
        { label: 'Dify KI-Agenten' },
      ]} />
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#dcfce7;color:#166534;">Aktualisiert März 2026</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#fef9c3;color:#713f12;">KI-Agenten</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#ede9fe;color:#4c1d95;">Fortgeschritten</span>
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:#fff;line-height:1.2;margin-bottom:1rem;">
        Dify KI-Agenten Anleitung 2026: Autonome KI mit Tools bauen
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:680px;line-height:1.7;">
        Dify KI-Agenten gehen weit über einfache Chatbots hinaus — sie können das Web durchsuchen, Python-Code ausführen, beliebige APIs aufrufen und mehrstufige Aufgaben autonom lösen. Diese Anleitung erklärt alles: vom ersten Agenten bis hin zu Custom Tools und Multi-Agenten-Systemen.
      </p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1.5rem;">
        <a href="#agent-erstellen" style="display:inline-flex;align-items:center;padding:0.65rem 1.25rem;border-radius:0.5rem;font-weight:600;text-decoration:none;background:#1677FF;color:#fff;font-size:0.9rem;">
          Ersten Agenten erstellen →
        </a>
        <a href="#eingebaute-tools" style="display:inline-flex;align-items:center;padding:0.65rem 1.25rem;border-radius:0.5rem;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,0.2);color:#e2e8f0;font-size:0.9rem;">
          Tools entdecken
        </a>
      </div>
    </div>
  </section>

  <!-- Was sind Dify KI-Agenten -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Was sind Dify KI-Agenten?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        Ein Dify KI-Agent ist eine KI-Anwendung, die autonom entscheidet, welche Tools sie nutzen soll, um eine Aufgabe zu erfüllen. Im Gegensatz zu einem gewöhnlichen Chatbot, der nur Text basierend auf dem Prompt erzeugt, kann ein Agent reale Aktionen ausführen: Google durchsuchen, einen Wikipedia-Artikel lesen, ein Python-Skript ausführen, das aktuelle Wetter abrufen oder eine beliebige REST-API aufrufen.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Der entscheidende Unterschied ist die <strong>Handlungsfähigkeit</strong>: Du gibst dem Agenten ein Ziel (z.B. "Recherchiere die Top 5 KI-Startups 2026 und fasse ihre Finanzierung zusammen"), und der Agent bestimmt selbstständig die notwendigen Schritte — Web-Suche, Ergebnisse lesen, Informationen filtern und eine Antwort zusammenstellen.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.75rem;">
        {[
          { icon: '🔍', label: 'Web in Echtzeit durchsuchen', bg: '#eff6ff', color: '#1e40af' },
          { icon: '🐍', label: 'Python-Code ausführen', bg: '#f0fdf4', color: '#166534' },
          { icon: '🔗', label: 'Beliebige REST-APIs aufrufen', bg: '#fdf4ff', color: '#6b21a8' },
          { icon: '🧮', label: 'Berechnungen durchführen', bg: '#fff7ed', color: '#9a3412' },
          { icon: '📚', label: 'Wikipedia abfragen', bg: '#eff6ff', color: '#1e40af' },
          { icon: '🤔', label: 'Schritt-für-Schritt denken', bg: '#f0fdf4', color: '#166534' },
        ].map(f => (
          <div style={`display:flex;align-items:center;gap:0.5rem;background:${f.bg};padding:0.75rem;border-radius:0.5rem;`}>
            <span style="font-size:1.1rem;">{f.icon}</span>
            <span style={`font-size:0.875rem;font-weight:600;color:${f.color};`}>{f.label}</span>
          </div>
        ))}
      </div>
      <div style="background:#fef9c3;border-left:3px solid #f59e0b;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;margin-top:1.5rem;font-size:0.875rem;color:#713f12;">
        <strong>Praxisbeispiel:</strong> Frage einen Dify Agenten: "Was ist der aktuelle Bitcoin-Kurs und wie hat er sich diese Woche entwickelt?" — Der Agent nutzt Google Search, liest die Ergebnisse und liefert eine aktuelle, präzise Antwort. Ein normaler Chatbot kann das nicht.
      </div>
    </div>
  </section>

  <!-- Agent vs Chatbot vs Workflow -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Agent vs. Chatbot vs. Workflow — Wann was nutzen?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify bietet drei Haupttypen von Apps. Das Verständnis, wann welcher Typ am besten geeignet ist, spart Zeit und liefert bessere Ergebnisse:
      </p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
          <thead>
            <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0;">
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;min-width:100px;">Merkmal</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#374151;">Chatbot</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#374151;">Workflow</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#1677FF;">Agent</th>
            </tr>
          </thead>
          <tbody>
            {[
              { feature: 'Tool-Nutzung', chatbot: '✗ Keine', workflow: '✓ Feste Tools', agent: '✓ Dynamische Wahl' },
              { feature: 'Entscheidung', chatbot: 'Keine', workflow: 'Feste Verzweigungen', agent: 'Autonomes Reasoning' },
              { feature: 'Ideal für', chatbot: 'Q&A, Support-Bots', workflow: 'Pipelines, Automatisierung', agent: 'Recherche, komplexe Tasks' },
              { feature: 'Schritte', chatbot: '1 Schritt (Prompt → Antwort)', workflow: 'Vordefinierte Schritte', agent: 'Variabel, zur Laufzeit' },
              { feature: 'Echtzeit-Daten', chatbot: '✗ Nein', workflow: 'Nur via HTTP-Nodes', agent: '✓ Ja, via Tools' },
              { feature: 'Vorhersagbarkeit', chatbot: 'Hoch', workflow: 'Sehr hoch', agent: 'Niedriger (flexibel)' },
            ].map((row, i) => (
              <tr style={`border-bottom:1px solid #f3f4f6;${i % 2 === 0 ? 'background:#fff;' : 'background:#f8fafc;'}`}>
                <td style="padding:0.65rem 1rem;font-weight:600;color:#111827;">{row.feature}</td>
                <td style="padding:0.65rem 1rem;color:#6B7280;">{row.chatbot}</td>
                <td style="padding:0.65rem 1rem;color:#6B7280;">{row.workflow}</td>
                <td style="padding:0.65rem 1rem;color:#1677FF;font-weight:600;">{row.agent}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;margin-top:1.5rem;">
        <div style="background:#f0fdf4;border-radius:0.75rem;padding:1rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#14532d;margin-bottom:0.4rem;">Chatbot verwenden wenn...</h3>
          <p style="font-size:0.85rem;color:#166534;margin:0;line-height:1.6;">Du einen einfachen Gesprächsassistenten für Kundensupport, FAQ-Beantwortung oder Helpdesk benötigst. Statisches Wissen, keine Echtzeit-Daten nötig.</p>
        </div>
        <div style="background:#eff6ff;border-radius:0.75rem;padding:1rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#1e3a8a;margin-bottom:0.4rem;">Workflow verwenden wenn...</h3>
          <p style="font-size:0.85rem;color:#1e40af;margin:0;line-height:1.6;">Du eine wiederholbare, deterministische Pipeline hast: Text übersetzen, Artikel zusammenfassen, Support-Tickets klassifizieren. Immer dieselben Schritte.</p>
        </div>
        <div style="background:#fdf4ff;border-radius:0.75rem;padding:1rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#581c87;margin-bottom:0.4rem;">Agent verwenden wenn...</h3>
          <p style="font-size:0.85rem;color:#6b21a8;margin:0;line-height:1.6;">Die Aufgabe Echtzeit-Informationen, mehrere Tools oder dynamische Entscheidungen erfordert. Recherche, Wettbewerbsanalyse, Live-Datenabrufe oder komplexe mehrstufige Aufgaben.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ersten Agenten erstellen -->
  <section id="agent-erstellen" class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">3</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Deinen ersten Dify Agenten erstellen</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Folge diesen Schritten, um einen Research-Agenten zu bauen, der im Web suchen und Berechnungen durchführen kann. Das dauert etwa 10 Minuten:
      </p>
      <div style="display:grid;gap:1rem;max-width:660px;margin-bottom:1.5rem;">
        {[
          { step: '1', title: 'Neue App erstellen', desc: 'Klicke in Dify Studio auf "+ App erstellen". Wenn du nach dem Typ gefragt wirst, wähle "Agent". Gib einen Namen ein, z.B. "Recherche-Assistent".' },
          { step: '2', title: 'System-Prompt schreiben', desc: 'Beschreibe die Rolle des Agenten. Beispiel: "Du bist ein Recherche-Assistent. Wenn aktuelle Informationen benötigt werden, nutze Google Search. Verwende den Calculator für Berechnungen. Zitiere immer deine Quellen."' },
          { step: '3', title: 'Tools hinzufügen', desc: 'Im Bereich "Tools" (linkes Panel) klicke auf "+ Tool hinzufügen". Aktiviere "Google Search" — du benötigst einen SerpAPI-Schlüssel (kostenloses Kontingent verfügbar). Aktiviere außerdem "Calculator" — kein API-Schlüssel nötig.' },
          { step: '4', title: 'Agenten-Strategie wählen', desc: 'Unter "Agenten-Strategie" wähle "Function Calling" für GPT-4o oder Claude-Modelle. Wähle "ReAct" für Open-Source-Modelle ohne natives Function Calling.' },
          { step: '5', title: 'Modell auswählen', desc: 'Wähle GPT-4o oder Claude 3.5 Sonnet für beste Agenten-Performance. Diese Modelle verstehen am zuverlässigsten, wann und wie sie Tools verwenden sollen.' },
          { step: '6', title: 'Agenten testen', desc: 'Im Vorschau-Panel, tippe: "Was ist der aktuelle Bitcoin-Kurs in Euro?" — Beobachte, wie der Agent Google Search aufruft, die Ergebnisse liest und eine aktuelle Antwort liefert. Dann: "Wenn ich 0,5 BTC zu diesem Kurs kaufe, was kostet mich das?"' },
          { step: '7', title: 'Veröffentlichen', desc: 'Klicke auf den blauen "Veröffentlichen"-Button. Dein Agent ist jetzt live und über den Share-Link oder die REST-API zugänglich.' },
        ].map(s => (
          <div class="card" style="display:flex;gap:1rem;align-items:flex-start;padding:1rem;">
            <span style="width:1.75rem;height:1.75rem;background:#eff6ff;color:#1677FF;border:2px solid #1677FF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;flex-shrink:0;">{s.step}</span>
            <div>
              <p style="font-weight:700;font-size:0.9rem;color:#111827;margin:0 0 0.25rem;">{s.title}</p>
              <p style="font-size:0.85rem;color:#4B5563;margin:0;line-height:1.5;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="background:#f0fdf4;border-left:3px solid #16a34a;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#166534;">
        <strong>Profi-Tipp:</strong> Halte den System-Prompt fokussiert. Erkläre dem Agenten genau, was er ist, welche Tools er bevorzugen soll und wie er Antworten formatieren soll. Vage Prompts führen zu inkonsistenter Tool-Nutzung.
      </div>
    </div>
  </section>

  <!-- Eingebaute Tools -->
  <section id="eingebaute-tools" class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Eingebaute Tools für Dify Agenten</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify enthält eine Bibliothek gebrauchsfertiger Tools. Die meisten benötigen einen kostenlosen oder kostenpflichtigen API-Schlüssel des jeweiligen Anbieters. Hier sind die nützlichsten:
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;">
        {[
          {
            name: 'Google Search',
            icon: '🔍',
            provider: 'SerpAPI',
            desc: 'Durchsucht Google und liefert die Top-Ergebnisse mit Titeln, Snippets und URLs. Das leistungsstärkste Such-Tool — ideal für aktuelle Nachrichten, Preise, Unternehmensdaten und zeitkritische Informationen.',
            keyRequired: 'SerpAPI-Schlüssel (100 kostenlose Suchen/Monat)',
            badge: 'Am häufigsten genutzt',
            badgeColor: '#1677FF',
          },
          {
            name: 'DuckDuckGo',
            icon: '🦆',
            provider: 'Eingebaut',
            desc: 'Datenschutzorientierte Websuche ohne API-Schlüssel. Gut für allgemeine Suchen. Etwas weniger zuverlässig als Google Search für sehr aktuelle Informationen.',
            keyRequired: 'Keiner — kostenlos',
            badge: 'Kein Schlüssel nötig',
            badgeColor: '#16a34a',
          },
          {
            name: 'Bing Search',
            icon: '🔎',
            provider: 'Microsoft Azure',
            desc: 'Microsofts Suchmaschine über Azure Cognitive Services. Solide Alternative zu SerpAPI mit großzügigem Gratis-Kontingent (1.000 Transaktionen/Monat).',
            keyRequired: 'Azure Bing Search API-Schlüssel',
            badge: 'Gutes Gratis-Tier',
            badgeColor: '#16a34a',
          },
          {
            name: 'Wikipedia',
            icon: '📚',
            provider: 'Eingebaut',
            desc: 'Durchsucht Wikipedia und gibt den vollständigen Artikeltext zurück. Ideal für sachliches, enzyklopädisches Wissen. Viel zuverlässiger als Web-Suche für stabile Fakten.',
            keyRequired: 'Keiner — kostenlos',
            badge: 'Kein Schlüssel nötig',
            badgeColor: '#16a34a',
          },
          {
            name: 'Calculator',
            icon: '🧮',
            provider: 'Eingebaut',
            desc: 'Wertet mathematische Ausdrücke aus. Verhindert, dass das Modell versucht, Arithmetik im Kopf zu berechnen (LLMs sind bekanntermaßen schlecht in Mathe). Ideal für Preisberechnungen, Prozentsätze und Statistiken.',
            keyRequired: 'Keiner — kostenlos',
            badge: 'Kein Schlüssel nötig',
            badgeColor: '#16a34a',
          },
          {
            name: 'Code Interpreter',
            icon: '🐍',
            provider: 'Eingebaut (Sandbox)',
            desc: 'Führt Python-Code in einer sicheren Sandbox aus. Der Agent kann Code schreiben und ausführen, um Daten zu analysieren, Text zu verarbeiten, komplexe Berechnungen durchzuführen oder Dateien zu manipulieren.',
            keyRequired: 'Keiner — läuft lokal in Dify',
            badge: 'Sehr mächtig',
            badgeColor: '#7c3aed',
          },
          {
            name: 'Wetter',
            icon: '🌤',
            provider: 'OpenWeatherMap',
            desc: 'Gibt aktuelle Wetterbedingungen und Vorhersagen für beliebige Orte zurück. Nützlich für Reise-Agenten, Event-Planung oder standortbezogene Anwendungen.',
            keyRequired: 'OpenWeatherMap API-Schlüssel (Gratis-Tier verfügbar)',
            badge: 'Gratis-Tier',
            badgeColor: '#16a34a',
          },
          {
            name: 'WolframAlpha',
            icon: '🧠',
            provider: 'Wolfram',
            desc: 'Computationelle Intelligenz — beantwortet Mathe-Probleme, wissenschaftliche Fragen, historische Daten, Einheitenumrechnungen mit höchster Genauigkeit. Hervorragende Ergänzung zur Web-Suche.',
            keyRequired: 'Wolfram API-Schlüssel (2.000 kostenlose Aufrufe/Monat)',
            badge: 'Sehr präzise',
            badgeColor: '#d97706',
          },
        ].map(tool => (
          <div class="card" style="padding:1.25rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.75rem;">
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <span style="font-size:1.25rem;">{tool.icon}</span>
                <h3 style="font-size:1rem;font-weight:700;color:#111827;margin:0;">{tool.name}</h3>
              </div>
              <span style={`font-size:0.7rem;font-weight:700;padding:0.15rem 0.5rem;border-radius:9999px;white-space:nowrap;background:${tool.badgeColor}1a;color:${tool.badgeColor};`}>{tool.badge}</span>
            </div>
            <p style="font-size:0.82rem;color:#6B7280;margin:0 0 0.5rem;line-height:1.5;">{tool.desc}</p>
            <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.5rem;">
              <span style="font-size:0.75rem;color:#9CA3AF;">Anbieter:</span>
              <span style="font-size:0.75rem;font-weight:600;color:#374151;">{tool.provider}</span>
            </div>
            <div style="background:#f8fafc;border-radius:0.375rem;padding:0.4rem 0.6rem;margin-top:0.5rem;">
              <span style="font-size:0.75rem;color:#6B7280;">Schlüssel: </span>
              <span style="font-size:0.75rem;color:#374151;">{tool.keyRequired}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom Tool Integration -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Custom Tools: Beliebige APIs verbinden</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Die eigentliche Stärke von Dify Agenten liegt darin, dass du jede beliebige REST-API als Custom Tool einbinden kannst. So kann dein Agent mit internen Firmensystemen, SaaS-Tools, Datenbanken oder anderen Diensten mit API interagieren.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;margin-bottom:1.5rem;">
        <div style="background:#eff6ff;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.95rem;font-weight:700;color:#1e40af;margin-bottom:0.75rem;">Methode 1: OpenAPI-Schema</h3>
          <p style="font-size:0.85rem;color:#1e40af;line-height:1.5;margin:0 0 0.75rem;">Hat deine API eine OpenAPI (Swagger) Spezifikation, füge das JSON oder YAML direkt in Dify ein. Es parst automatisch alle Endpunkte, Parameter und Beschreibungen.</p>
          <ol style="font-size:0.82rem;color:#1e40af;line-height:1.8;margin:0;padding-left:1.1rem;">
            <li>Tools → Custom Tools → Tool erstellen</li>
            <li>"Aus OpenAPI-Schema importieren" auswählen</li>
            <li>OpenAPI JSON/YAML einfügen</li>
            <li>Authentifizierung hinzufügen (API-Key, Bearer-Token usw.)</li>
            <li>Speichern — alle Endpunkte stehen als Tools bereit</li>
          </ol>
        </div>
        <div style="background:#f0fdf4;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.95rem;font-weight:700;color:#14532d;margin-bottom:0.75rem;">Methode 2: Manuelle Definition</h3>
          <p style="font-size:0.85rem;color:#166534;line-height:1.5;margin:0 0 0.75rem;">Für einfache APIs ohne formale Spezifikation definiere jeden Endpunkt manuell:</p>
          <ol style="font-size:0.82rem;color:#166534;line-height:1.8;margin:0;padding-left:1.1rem;">
            <li>Name: "hole_kundendaten" (wie der Agent es nennt)</li>
            <li>Beschreibung: "Sucht einen Kunden anhand der E-Mail-Adresse" (der Agent liest dies, um zu entscheiden, wann er das Tool nutzt)</li>
            <li>Methode: GET, POST, PUT, DELETE</li>
            <li>URL: Deine Endpunkt-URL mit Parametern</li>
            <li>Parameter: Name, Typ, Beschreibung, Pflicht/Optional</li>
          </ol>
        </div>
      </div>
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:0.75rem;padding:1.25rem;">
        <h3 style="font-size:0.95rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Beispiel: CRM-API-Tool</h3>
        <div style="background:#1e293b;border-radius:0.5rem;padding:1rem;overflow-x:auto;">
          <pre style="margin:0;font-size:0.8rem;color:#e2e8f0;font-family:monospace;line-height:1.6;">{`Tool-Name: hole_kundeninfo
Beschreibung: Ruft Kundendaten aus der CRM-Datenbank
              anhand der Kunden-E-Mail ab. Verwende dies,
              wenn nach dem Kontostatus eines Kunden gefragt wird.

Methode: GET
URL: https://api.ihrecrm.de/customers?email={{email}}

Parameter:
  - email (string, Pflichtfeld): E-Mail des Kunden

Header:
  Authorization: Bearer {{api_key}}`}</pre>
        </div>
        <p style="font-size:0.82rem;color:#6B7280;margin:0.75rem 0 0;line-height:1.5;">Einmal konfiguriert, kann dein Agent Fragen beantworten wie "Was ist der Abonnement-Status von max@beispiel.de?" indem er automatisch deine CRM-API aufruft.</p>
      </div>
    </div>
  </section>

  <!-- ReAct vs Function Calling -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Agenten-Strategien: ReAct vs. Function Calling</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify unterstützt zwei Strategien für das Reasoning und die Tool-Nutzung von Agenten. Die richtige Wahl hängt vom verwendeten LLM ab:
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;margin-bottom:1.5rem;">
        <div style="background:#fff;border:2px solid #1677FF;border-radius:0.75rem;padding:1.5rem;">
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <span style="background:#1677FF;color:#fff;padding:0.15rem 0.5rem;border-radius:9999px;font-size:0.75rem;font-weight:700;">Empfohlen</span>
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin:0;">Function Calling</h3>
          </div>
          <p style="font-size:0.875rem;color:#4B5563;line-height:1.6;margin:0 0 0.75rem;">Das Modell versteht nativ, wie es Tools als strukturierte Funktionsaufrufe verwenden soll. Zuverlässiger, effizienter und erzeugt sauberere Reasoning-Ketten.</p>
          <div style="background:#eff6ff;border-radius:0.5rem;padding:0.75rem;margin-bottom:0.75rem;">
            <p style="font-size:0.8rem;font-weight:700;color:#1e40af;margin:0 0 0.3rem;">Beste Modelle:</p>
            <ul style="font-size:0.8rem;color:#1e40af;margin:0;padding-left:1.1rem;line-height:1.7;">
              <li>GPT-4o, GPT-4 Turbo</li>
              <li>Claude 3.5 Sonnet, Claude 3 Opus</li>
              <li>Gemini 1.5 Pro, Gemini 1.5 Flash</li>
              <li>Mistral Large</li>
            </ul>
          </div>
        </div>
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:0.75rem;padding:1.5rem;">
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <span style="background:#f59e0b;color:#fff;padding:0.15rem 0.5rem;border-radius:9999px;font-size:0.75rem;font-weight:700;">Universal</span>
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin:0;">ReAct (Reasoning + Acting)</h3>
          </div>
          <p style="font-size:0.875rem;color:#4B5563;line-height:1.6;margin:0 0 0.75rem;">Das Modell schreibt sein Reasoning als Text ("Gedanke: Ich muss X suchen...") gefolgt von Aktionsanweisungen ("Aktion: google_search[X]"). Funktioniert mit jedem Modell, das Anweisungen befolgen kann.</p>
          <div style="background:#fff7ed;border-radius:0.5rem;padding:0.75rem;margin-bottom:0.75rem;">
            <p style="font-size:0.8rem;font-weight:700;color:#9a3412;margin:0 0 0.3rem;">Wann einsetzen:</p>
            <ul style="font-size:0.8rem;color:#9a3412;margin:0;padding-left:1.1rem;line-height:1.7;">
              <li>Open-Source-Modelle (Llama, Qwen, Mistral 7B)</li>
              <li>Modelle ohne natives Function Calling</li>
              <li>Wenn du das vollständige Reasoning sehen möchtest</li>
            </ul>
          </div>
        </div>
      </div>
      <div style="background:#f8fafc;border-radius:0.75rem;padding:1.25rem;">
        <h3 style="font-size:0.9rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Kurzregel</h3>
        <p style="font-size:0.875rem;color:#4B5563;margin:0;line-height:1.6;">Verwendest du GPT-4o, Claude 3.5+ oder Gemini Pro? → Nimm <strong>Function Calling</strong>. Verwendest du ein Open-Source-Modell? → Nimm <strong>ReAct</strong>. Im Zweifelsfall zuerst Function Calling ausprobieren.</p>
      </div>
    </div>
  </section>

  <!-- Multi-Agenten-Orchestrierung -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Multi-Agenten-Orchestrierung</h2>
