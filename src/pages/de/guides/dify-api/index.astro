---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../../i18n/hreflang';

const hreflang = getHreflang('/guides/dify-api/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Dify API Anleitung 2026: KI per REST in deine App integrieren',
  description: 'Vollständige Dify API Anleitung. Lerne Authentifizierung, Chat-Endpunkte, Streaming und die Integration von Dify KI in beliebige Apps via REST. Mit curl- und Python-Beispielen.',
  datePublished: '2026-01-01',
  dateModified: '2026-03-24',
  author: { '@type': 'Organization', name: 'Dify Hosting' },
};

const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Wie bekomme ich einen Dify API-Schlüssel?","acceptedAnswer":{"@type":"Answer","text":"Öffne deine Dify-App, klicke oben rechts auf 'API Access' und erstelle einen neuen API-Schlüssel. Kopiere den Secret Key — er wird nur einmal angezeigt. Verwende ihn im Authorization-Header als 'Bearer DEIN_KEY'."}},{"@type":"Question","name":"Ist die Dify API kostenlos?","acceptedAnswer":{"@type":"Answer","text":"Die Dify API selbst ist kostenlos — du zahlst nur für die verbrauchten LLM-Token (OpenAI, Anthropic usw.). Self-hosted Dify hat keine API-Kosten. Dify Cloud berechnet nach Message Credits."}},{"@type":"Question","name":"Kann ich Dify API-Antworten streamen?","acceptedAnswer":{"@type":"Answer","text":"Ja. Setze 'response_mode':'streaming' im Request-Body, um Server-Sent Events (SSE) zu erhalten. So kannst du Tokens anzeigen, während sie generiert werden — wie bei ChatGPT."}},{"@type":"Question","name":"Welche Programmiersprachen funktionieren mit der Dify API?","acceptedAnswer":{"@type":"Answer","text":"Jede Sprache, die HTTP-Requests unterstützt: Python, JavaScript/Node.js, PHP, Ruby, Go, Java, C# und mehr. Dify bietet offizielle SDKs für Python und Node.js sowie curl-Beispiele für jeden Endpunkt."}}]};
---

<BaseLayout
  title="Dify API Anleitung 2026: KI per REST in deine App integrieren"
  description="Vollständige Dify API Anleitung. Lerne Authentifizierung, Chat-Endpunkte, Streaming und die Integration von Dify KI in beliebige Apps via REST. Mit curl- und Python-Beispielen."
  lang="de"
  canonical="https://dify-hosting.com/de/guides/dify-api/"
  hreflang={hreflang}
  schema={[schema, faqSchema]}
>
  <!-- Hero -->
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Startseite', href: '/de/' },
        { label: 'Guides', href: '/de/guides/' },
        { label: 'Dify API Anleitung' },
      ]} />
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#dcfce7;color:#166534;">Aktualisiert März 2026</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#fef9c3;color:#713f12;">Entwickler-Guide</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#ede9fe;color:#4c1d95;">REST API</span>
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:#fff;line-height:1.2;margin-bottom:1rem;">
        Dify API Anleitung 2026: KI per REST in deine App integrieren
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:680px;line-height:1.7;">
        Die Dify REST API ermöglicht es dir, jede Dify-App aus eigenem Code heraus aufzurufen — einen Chatbot in deine Website einbetten, Dokumentenverarbeitung automatisieren oder KI-Funktionen in beliebige SaaS-Produkte integrieren. Diese Anleitung deckt alles ab: vom API-Schlüssel bis zu Streaming-Antworten und Self-Hosted-Setups.
      </p>
    </div>
  </section>

  <!-- Section 1: Was ist die Dify API? -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Was ist die Dify API?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        Die Dify API ist eine REST API, mit der du jede in Dify erstellte App programmatisch aufrufen kannst — aus jeder Programmiersprache oder Plattform. Sobald du eine Dify-App veröffentlichst (Chatbot, Agent, Workflow oder Completion-App), erhält sie einen eigenen API-Endpunkt, den du mit einem Secret Key aufrufen kannst.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Die Basis-URL für Dify Cloud ist <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;font-size:0.875rem;">https://api.dify.ai/v1</code>. Beim Self-Hosting ersetzt du diese durch deine eigene Domain: <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;font-size:0.875rem;">https://dein-server.com/v1</code>.
      </p>
      <h3 style="font-size:1.1rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Typische Anwendungsfälle</h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.75rem;margin-bottom:1.5rem;">
        {[
          { title: 'Website-Chatbot', desc: 'KI-Chat in jede Website einbetten, ohne das Dify-Widget zu nutzen.' },
          { title: 'Dokumentenautomatisierung', desc: 'PDFs oder Texte an einen Dify-Workflow senden und strukturierte Ausgabe erhalten.' },
          { title: 'SaaS KI-Funktionen', desc: 'KI-Schreiben, Zusammenfassung oder Q&A in bestehende Produkte einbauen.' },
          { title: 'Backend-Pipelines', desc: 'Dify-Agents aus Cron-Jobs, Webhooks oder Queue-Prozessoren auslösen.' },
          { title: 'Mobile Apps', desc: 'Dify aus iOS- oder Android-Apps über Standard-HTTP aufrufen.' },
          { title: 'No-Code-Tools', desc: 'Dify über HTTP-Request-Nodes mit n8n, Make oder Zapier verbinden.' },
        ].map(u => (
          <div style="background:#f8fafc;border-radius:0.5rem;padding:0.875rem;border-left:3px solid #1677FF;">
            <p style="font-weight:700;font-size:0.875rem;color:#111827;margin:0 0 0.3rem;">{u.title}</p>
            <p style="font-size:0.82rem;color:#6B7280;margin:0;line-height:1.5;">{u.desc}</p>
          </div>
        ))}
      </div>
      <div style="background:#f0f9ff;border-left:3px solid #1677FF;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#1e40af;">
        <strong>Hinweis:</strong> Jeder Dify-App-Typ (Chatbot, Agent, Workflow, Completion) hat leicht unterschiedliche Endpunkte. Diese Anleitung konzentriert sich auf die Chat Messages API, die am häufigsten verwendet wird.
      </div>
    </div>
  </section>

  <!-- Section 2: API-Schlüssel erstellen -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">API-Schlüssel erstellen</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.25rem;">
        Jede Dify-App hat ihren eigenen API-Schlüssel. Du musst für jede App, auf die du per API zugreifen möchtest, einen erstellen. So geht's:
      </p>
      <div style="display:grid;gap:0.75rem;max-width:620px;margin-bottom:1.5rem;">
        {[
          { step: '1', action: 'Öffne deine Dify-App im Studio', detail: 'Gehe zu cloud.dify.ai (oder deiner Self-Hosted URL) und öffne die App, die du per API aufrufen möchtest.' },
          { step: '2', action: 'Klicke oben rechts auf "API Access"', detail: 'Dies öffnet das API-Referenzpanel für genau diese App.' },
          { step: '3', action: 'Klicke auf "API Key erstellen"', detail: 'Gib ihm einen Namen (z.B. "produktion" oder "test"), um ihn später zu identifizieren.' },
          { step: '4', action: 'Kopiere den Secret Key sofort', detail: 'Der Key wird nur einmal angezeigt. Speichere ihn als Umgebungsvariable — niemals direkt im Quellcode.' },
          { step: '5', action: 'Verwende ihn im Authorization-Header', detail: 'Alle API-Anfragen benötigen diesen Header: Authorization: Bearer DEIN_API_KEY' },
        ].map(s => (
          <div style="display:flex;align-items:flex-start;gap:0.75rem;">
            <span style="width:1.75rem;height:1.75rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;flex-shrink:0;margin-top:0.1rem;">{s.step}</span>
            <div>
              <p style="font-weight:700;font-size:0.9rem;color:#111827;margin:0 0 0.2rem;">{s.action}</p>
              <p style="font-size:0.82rem;color:#6B7280;margin:0;line-height:1.5;">{s.detail}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="background:#fef2f2;border-left:3px solid #ef4444;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#991b1b;">
        <strong>Sicherheitswarnung:</strong> Expose deinen API-Schlüssel niemals in clientseitigem JavaScript oder in einem öffentlichen Repository. Speichere ihn immer als Umgebungsvariable und rufe die Dify API immer vom Backend-Server aus auf.
      </div>
    </div>
  </section>

  <!-- Section 3: API-Endpunkte -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Übersicht der API-Endpunkte</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Die Dify API bietet Endpunkte zum Senden von Nachrichten, Verwalten von Konversationen, Hochladen von Dateien und mehr. Alle Endpunkte sind relativ zur Basis-URL <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;font-size:0.875rem;">https://api.dify.ai/v1</code>.
      </p>
      <div style="overflow-x:auto;margin-bottom:1.5rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
          <thead>
            <tr style="background:#f8fafc;">
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:700;color:#374151;border-bottom:2px solid #e5e7eb;">Methode</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:700;color:#374151;border-bottom:2px solid #e5e7eb;">Endpunkt</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:700;color:#374151;border-bottom:2px solid #e5e7eb;">Beschreibung</th>
            </tr>
          </thead>
          <tbody>
            {[
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/chat-messages', desc: 'Chat-Nachricht senden und Antwort empfangen. Unterstützt blocking und streaming.' },
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/completion-messages', desc: 'Prompt an eine Completion-App senden. Gibt einen generierten Text zurück.' },
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/files/upload', desc: 'Datei hochladen (PDF, Bild usw.) für RAG oder Vision-Apps.' },
              { method: 'GET', color: '#1677FF', bg: '#eff6ff', endpoint: '/conversations', desc: 'Alle Konversationen eines Nutzers auflisten. Nutze den user-Parameter zur Filterung.' },
              { method: 'GET', color: '#1677FF', bg: '#eff6ff', endpoint: '/messages', desc: 'Nachrichtenverlauf einer bestimmten Konversation abrufen.' },
              { method: 'DELETE', color: '#dc2626', bg: '#fef2f2', endpoint: '/conversations/:id', desc: 'Eine Konversation und alle ihre Nachrichten dauerhaft löschen.' },
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/messages/:id/feedbacks', desc: 'Bewertung (Daumen hoch/runter) für eine bestimmte Nachricht abgeben.' },
              { method: 'GET', color: '#1677FF', bg: '#eff6ff', endpoint: '/parameters', desc: 'Eingabeparameter, Einführungstext und Vorschlagsfragen der App abrufen.' },
            ].map(r => (
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style={`padding:0.75rem 1rem;font-family:monospace;font-size:0.8rem;font-weight:700;color:${r.color};background:${r.bg};white-space:nowrap;`}>{r.method}</td>
                <td style="padding:0.75rem 1rem;font-family:monospace;font-size:0.8rem;color:#374151;white-space:nowrap;">{r.endpoint}</td>
                <td style="padding:0.75rem 1rem;color:#6B7280;line-height:1.5;">{r.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Section 4: Erster API-Aufruf -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Dein erster API-Aufruf</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Lass uns einen echten API-Aufruf durchführen. Ersetze <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">DEIN_API_KEY</code> durch deinen tatsächlichen Schlüssel. Das <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">user</code>-Feld ist ein eindeutiger Bezeichner für den Endnutzer — verwende einen beliebigen String, der diesen in deinem System identifiziert.
      </p>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">curl-Beispiel</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>curl -X POST 'https://api.dify.ai/v1/chat-messages' \
  -H 'Authorization: Bearer DEIN_API_KEY' \
  -H 'Content-Type: application/json' \
  -d '{"{"}
    "inputs": {"{"}{"}"},
    "query": "Hallo! Wobei kannst du mir helfen?",
    "response_mode": "blocking",
    "conversation_id": "",
    "user": "nutzer-123"
  {"}"}'</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Beispiel-Antwort</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>{"{"}
  "event": "message",
  "task_id": "abc123",
  "id": "msg_456",
  "message_id": "msg_456",
  "conversation_id": "conv_789",
  "mode": "chat",
  "answer": "Hallo! Ich kann dir bei Fragen, Texten, Analysen und vielem mehr helfen. Was möchtest du erkunden?",
  "metadata": {"{"} "usage": {"{"} "prompt_tokens": 12, "completion_tokens": 22 {"}"} {"}"},
  "created_at": 1711234567
{"}"}</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Python-Beispiel (mit requests)</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>import requests

API_KEY = "dein_api_key_hier"
BASE_URL = "https://api.dify.ai/v1"

def chat(query, conversation_id="", user="nutzer-123"):
    response = requests.post(
        f"{"{BASE_URL}"}/chat-messages",
        headers={"{"}
            "Authorization": f"Bearer {"{API_KEY}"}",
            "Content-Type": "application/json",
        {"}"},
        json={"{"}
            "inputs": {"{}"},
            "query": query,
            "response_mode": "blocking",
            "conversation_id": conversation_id,
            "user": user,
        {"}"}
    )
    response.raise_for_status()
    return response.json()

# Erste Nachricht
result = chat("Was ist Dify?")
print(result["answer"])
conversation_id = result["conversation_id"]

# Nachfolge in derselben Konversation
result2 = chat("Kannst du das näher erläutern?", conversation_id=conversation_id)
print(result2["answer"])</code></pre>

      <div style="background:#f0fdf4;border-left:3px solid #16a34a;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#166534;">
        <strong>Tipp:</strong> Speichere die <code>conversation_id</code> aus der ersten Antwort und übergib sie in Folgeaufrufen. So wird der Gesprächsverlauf beibehalten, und die KI erinnert sich an das Gesagte.
      </div>
    </div>
  </section>

  <!-- Section 5: Streaming -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Streaming-Antworten (SSE)</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        Streaming ermöglicht es, Tokens während der Generierung anzuzeigen — wie der Tipp-Effekt bei ChatGPT. Dify verwendet Server-Sent Events (SSE) für Streaming. Setze <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">"response_mode": "streaming"</code> im Request-Body.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Jedes Event kommt als Zeile mit dem Präfix <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">data:</code> an. Die Event-Typen umfassen <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">message</code> (ein Token-Chunk), <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">message_end</code> (Abschlussnachricht mit Metadaten) und <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">error</code>.
      </p>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Streaming curl-Beispiel</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>curl -X POST 'https://api.dify.ai/v1/chat-messages' \
  -H 'Authorization: Bearer DEIN_API_KEY' \
  -H 'Content-Type: application/json' \
  --no-buffer \
  -d '{"{"}
    "inputs": {"{"}{"}"},
    "query": "Schreib ein kurzes Gedicht über KI.",
    "response_mode": "streaming",
    "conversation_id": "",
    "user": "nutzer-123"
  {"}"}'</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Python Streaming-Beispiel</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>import requests
import json

def stream_chat(query, user="nutzer-123"):
    with requests.post(
        "https://api.dify.ai/v1/chat-messages",
        headers={"{"}
            "Authorization": "Bearer DEIN_API_KEY",
            "Content-Type": "application/json",
        {"}"},
        json={"{"}
            "inputs": {"{}"},
            "query": query,
            "response_mode": "streaming",
            "conversation_id": "",
            "user": user,
        {"}"},
        stream=True,
    ) as response:
        for line in response.iter_lines():
            if line and line.startswith(b"data: "):
                data = json.loads(line[6:])
                if data.get("event") == "message":
                    print(data["answer"], end="", flush=True)
                elif data.get("event") == "message_end":
                    print()
                    break

stream_chat("Erkläre Quantencomputing einfach.")</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">JavaScript / Browser (fetch mit ReadableStream)</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1rem;"><code>async function streamChat(query) {"{"}
  const response = await fetch("https://api.dify.ai/v1/chat-messages", {"{"}
    method: "POST",
    headers: {"{"}
      "Authorization": "Bearer DEIN_API_KEY",
      "Content-Type": "application/json",
    {"}"},
    body: JSON.stringify({"{"}
      inputs: {"{"}{"}"},
      query,
      response_mode: "streaming",
      conversation_id: "",
      user: "nutzer-browser",
    {"}"}),
  {"}"});

  const reader = response.body.getReader();
  const decoder = new TextDecoder();

  while (true) {"{"}
    const {"{"} done, value {"}"} = await reader.read();
    if (done) break;
    const lines = decoder.decode(value).split("\n");
    for (const line of lines) {"{"}
      if (line.startsWith("data: ")) {"{"}
        const data = JSON.parse(line.slice(6));
        if (data.event === "message") {"{"}
          document.getElementById("ausgabe").textContent += data.answer;
        {"}"}
      {"}"}
    {"}"}
  {"}"}
{"}"}

streamChat("Was sind die Vorteile von Self-Hosted KI?");</code></pre>
    </div>
  </section>

  <!-- Section 6: Self-Hosted API -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Dify API mit Self-Hosted-Installation</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        Wenn du Dify auf deinem eigenen Server hostest, funktioniert die API genauso — du ersetzt einfach die Basis-URL. Das ist der Hauptvorteil des Self-Hostings: Du kontrollierst die Infrastruktur, Daten bleiben auf deinem Server, und es gibt keine Limits für Message Credits.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;margin-bottom:1.5rem;">
        <div style="background:#f8fafc;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.95rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Dify Cloud</h3>
