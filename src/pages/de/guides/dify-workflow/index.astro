        <p style="color:#64748b;font-size:0.75rem;margin:0 0 0.5rem;font-family:monospace;">POST https://deine-dify-instanz/v1/workflows/run</p>
        <pre style="color:#e2e8f0;font-size:0.82rem;margin:0;line-height:1.7;font-family:monospace;">{`curl -X POST 'https://deine-dify-instanz/v1/workflows/run' \\
  -H 'Authorization: Bearer DEIN_API_KEY' \\
  -H 'Content-Type: application/json' \\
  -d '{
    "inputs": {
      "artikel_text": "Dein Artikelinhalt hier..."
