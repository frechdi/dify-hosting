---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../../i18n/hreflang';

const hreflang = getHreflang('/guides/dify-alternatives/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Die besten Dify-Alternativen 2026 — Flowise, n8n, LangFlow & mehr',
  description: 'Auf der Suche nach Dify-Alternativen? Wir vergleichen Flowise, n8n, LangFlow und OpenWebUI, um dir bei der Wahl der besten KI-App-Plattform zu helfen.',
  datePublished: '2026-01-01',
  dateModified: '2026-03-24',
  author: { '@type': 'Organization', name: 'Dify Hosting' },
};
---

<BaseLayout
  title="Die besten Dify-Alternativen 2026 — Flowise, n8n, LangFlow & mehr"
  description="Auf der Suche nach Dify-Alternativen? Wir vergleichen Flowise, n8n, LangFlow und OpenWebUI, um dir bei der Wahl der besten KI-App-Plattform zu helfen."
  lang="de"
  canonical="https://dify-hosting.com/de/guides/dify-alternatives/"
  hreflang={hreflang}
  schema={[schema, {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Was ist die beste Open-Source-Alternative zu Dify?","acceptedAnswer":{"@type":"Answer","text":"Flowise ist die naechste Alternative — beide sind visuelle LLM-App-Builder mit RAG-Unterstuetzung. Flowise ist einfacher, aber weniger funktionsreich."}},{"@type":"Question","name":"Ist Flowise besser als Dify?","acceptedAnswer":{"@type":"Answer","text":"Flowise ist einfacher und leichter, aber Dify hat mehr Funktionen: Multi-Modell-Unterstuetzung, eingebautes RAG, Workflow-Orchestrierung und eine produktionsreife API."}},{"@type":"Question","name":"Koennen Dify-Alternativen selbst gehostet werden?","acceptedAnswer":{"@type":"Answer","text":"Ja — Flowise, LangFlow, n8n und OpenWebUI sind alle vollstaendig Open-Source und ueber Docker selbst hostbar."}},{"@type":"Question","name":"Was ist der Unterschied zwischen Dify und LangFlow?","acceptedAnswer":{"@type":"Answer","text":"Beide verwenden einen visuellen knotenbasierten Editor. LangFlow ist codeorientierter; Dify ist produktfokussierter mit einer eingebauten Chat-UI."}}]}]}
>
  <!-- Hero -->
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Startseite', href: '/de/' },
        { label: 'Guides', href: '/de/guides/' },
        { label: 'Dify-Alternativen' },
      ]} />
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#dcfce7;color:#166534;">Aktualisiert März 2026</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#fef9c3;color:#713f12;">5 Tools verglichen</span>
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:#fff;line-height:1.2;margin-bottom:1rem;">
        Die besten Dify-Alternativen 2026
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:680px;line-height:1.7;">
        Dify ist die führende Open-Source-LLM-App-Plattform — aber sie ist nicht für jeden geeignet. Wir haben die besten Alternativen (Flowise, n8n, LangFlow, OpenWebUI) verglichen, damit du das richtige Tool für deinen spezifischen Anwendungsfall wählen kannst.
      </p>
    </div>
  </section>

  <!-- Warum Alternativen suchen -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Warum nach Dify-Alternativen suchen?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify ist für die meisten KI-App-Entwicklungsanwendungsfälle hervorragend — aber es gibt legitime Gründe, Alternativen in Betracht zu ziehen:
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;">
        {[
          { title: 'Einfacherer Anwendungsfall', desc: 'Du brauchst nur eine einfache LLM-Kette oder einen simplen Chatbot — Difys voller Funktionsumfang könnte übertrieben sein.' },
          { title: 'Nicht-LLM-Workflows', desc: 'Deine Automatisierung beinhaltet hauptsächlich Geschäftslogik und SaaS-Integrationen mit minimalem KI-Anteil.' },
          { title: 'Reine Open-Source-Anforderung', desc: 'Du brauchst ein Tool ohne Cloud-SaaS-Version und vollständig community-getriebener Entwicklung.' },
          { title: 'Spezifische Integrationen', desc: 'Du brauchst eine tiefe native Integration mit einem Framework wie LangChain oder einem bestimmten Vektorspeicher.' },
        ].map(r => (
          <div class="card">
            <h3 style="font-size:0.95rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">{r.title}</h3>
            <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.5;">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kurzübersicht -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Kurzübersicht</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">Alle Tools unten sind Open Source und self-hostbar. So vergleichen sie sich:</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
          <thead>
            <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0;">
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;color:#374151;">Tool</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;color:#374151;">Typ</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;color:#374151;">Self-Host</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;color:#374151;">Cloud-Preis</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;color:#374151;">Am besten für</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;color:#374151;">GitHub-Sterne</th>
            </tr>
          </thead>
          <tbody>
            {[
              { tool: 'Dify', type: 'LLM-App-Plattform', host: '✅ Kostenlos', price: 'Kostenlos / 59 $/Monat+', best: 'Produktions-KI-Apps & Agenten', stars: '90k+' },
              { tool: 'Flowise', type: 'Visueller LLM-Builder', host: '✅ Kostenlos', price: 'Kostenlos (nur Self-Host)', best: 'Einfache LLM-Ketten & Chatbots', stars: '35k+' },
              { tool: 'n8n', type: 'Workflow-Automatisierung', host: '✅ Kostenlos', price: '20–50+ $/Monat', best: 'Geschäftsprozessautomatisierung', stars: '50k+' },
              { tool: 'LangFlow', type: 'LangChain Visual IDE', host: '✅ Kostenlos', price: 'Kostenlos (nur Self-Host)', best: 'LangChain-Power-User', stars: '40k+' },
              { tool: 'OpenWebUI', type: 'LLM-Chat-Interface', host: '✅ Kostenlos', price: 'Kostenlos (nur Self-Host)', best: 'Lokale Modell-Chat-Interfaces', stars: '60k+' },
            ].map((row, i) => (
              <tr style={`border-bottom:1px solid #e5e7eb;${i % 2 === 0 ? '' : 'background:#f9fafb;'}`}>
                <td style={`padding:0.75rem 1rem;font-weight:700;color:${i === 0 ? '#1677FF' : '#111827'};`}>{row.tool}{i === 0 ? ' ★' : ''}</td>
                <td style="padding:0.75rem 1rem;color:#374151;">{row.type}</td>
                <td style="padding:0.75rem 1rem;color:#374151;">{row.host}</td>
                <td style="padding:0.75rem 1rem;color:#374151;">{row.price}</td>
                <td style="padding:0.75rem 1rem;color:#374151;">{row.best}</td>
                <td style="padding:0.75rem 1rem;color:#374151;">{row.stars}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Flowise -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Flowise — Der einfachste LLM-Flow-Builder</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.25rem;">
        Flowise ist ein Drag-and-Drop-Visual-Builder für LLM-Anwendungen. Er ist auf LangChain aufgebaut und ermöglicht die Erstellung von Chains, Agenten und Chatbots durch das Verbinden von vorgefertigten Komponenten auf einem Canvas. Es ist die einsteigerfreundlichste Option zum Bauen von LLM-gestützten Tools.
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#14532d;margin-bottom:0.5rem;">Flowise Stärken</h3>
          <ul style="color:#166534;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>Sehr einfacher Einstieg — kein Code nötig</li>
            <li>Gut für einfache RAG-Chatbots und Q&A-Bots</li>
            <li>Große Bibliothek vorgefertigter LangChain-Komponenten</li>
            <li>Leichtgewichtig — läuft auf minimalen Ressourcen</li>
          </ul>
        </div>
        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#7f1d1d;margin-bottom:0.5rem;">Flowise Einschränkungen</h3>
          <ul style="color:#991b1b;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>Kein integriertes User-Management oder Team-Features</li>
            <li>Eingeschränkte Produktionsreife für komplexe Apps</li>
            <li>Weniger aktive Entwicklung als Dify</li>
            <li>Keine Cloud-Option — nur Self-Host</li>
          </ul>
        </div>
      </div>
      <div style="background:#f8fafc;border-radius:0.75rem;padding:1rem;font-size:0.875rem;color:#374151;">
        <strong>Am besten für:</strong> Einzelentwickler oder kleine Teams, die einfache RAG-Chatbots oder LLM-Ketten bauen. Nicht empfohlen für Produktions-Apps mit mehreren Nutzern oder komplexen agentischen Workflows.
      </div>
    </div>
  </section>

  <!-- n8n -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">n8n — Am besten für Automatisierung mit KI als Beimischung</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.25rem;">
        n8n ist eine Workflow-Automatisierungsplattform mit LLM-Fähigkeiten — nicht umgekehrt. Es verbindet sich mit 400+ Diensten und ist hervorragend für die Automatisierung von Geschäftsprozessen. Wenn dein Anwendungsfall "einen Workflow starten, wenn X passiert, und irgendwo in der Mitte ein KI-Modell aufrufen" lautet, ist n8n wahrscheinlich das bessere Tool.
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#14532d;margin-bottom:0.5rem;">n8n Stärken</h3>
          <ul style="color:#166534;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>400+ Integrationen mit SaaS-Tools</li>
            <li>Erstklassige Workflow-Zuverlässigkeit und Fehlerbehandlung</li>
            <li>Starke Community und umfangreiche Template-Bibliothek</li>
            <li>Cloud-Option verfügbar (auch self-hostbar)</li>
          </ul>
        </div>
        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#7f1d1d;margin-bottom:0.5rem;">n8n Einschränkungen</h3>
          <ul style="color:#991b1b;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>Nicht für KI-First-Anwendungen konzipiert</li>
            <li>Kein RAG, keine Wissensdatenbank oder Agentengedächtnis</li>
            <li>Fair-Code-Lizenz (nicht vollständig Open Source)</li>
            <li>Cloud-Plan ab 20 $/Monat (kein kostenloser Tarif)</li>
          </ul>
        </div>
      </div>
      <div style="background:#f8fafc;border-radius:0.75rem;padding:1rem;font-size:0.875rem;color:#374151;">
        <strong>Am besten für:</strong> Business-Automatisierungsteams, die KI als einen Schritt in einem größeren Workflow benötigen. Wird oft zusammen mit Dify verwendet — n8n handhabt Trigger und Integrationen, Dify handhabt die KI-Logik.
      </div>
    </div>
  </section>

  <!-- LangFlow -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">LangFlow — Für LangChain-Power-User</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.25rem;">
        LangFlow ist eine visuelle IDE für LangChain. Es bietet eine Drag-and-Drop-Oberfläche zum Erstellen, Testen und Exportieren von LangChain-Pipelines. Wenn du bereits tief im LangChain-Ökosystem bist und eine visuelle Oberfläche zum Entwerfen deiner Chains möchtest, ist LangFlow eine natürliche Wahl — aber es ist entwicklerorientierter als Dify.
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#14532d;margin-bottom:0.5rem;">LangFlow Stärken</h3>
          <ul style="color:#166534;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>Native LangChain-Unterstützung — jede LangChain-Komponente nutzbar</li>
            <li>Gut für das Prototyping komplexer Chain-Architekturen</li>
            <li>Export von Flows als Python-Code</li>
            <li>Aktive, von DataStax unterstützte Entwicklung</li>
          </ul>
        </div>
        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#7f1d1d;margin-bottom:0.5rem;">LangFlow Einschränkungen</h3>
          <ul style="color:#991b1b;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>Entwicklerorientierter — steilere Lernkurve</li>
            <li>Weniger ausgereiftes UX als Dify</li>
            <li>Kein integriertes App-Publishing oder -Sharing</li>
            <li>Eingeschränktes User-Management für Teams</li>
          </ul>
        </div>
      </div>
      <div style="background:#f8fafc;border-radius:0.75rem;padding:1rem;font-size:0.875rem;color:#374151;">
        <strong>Am besten für:</strong> Python-Entwickler, die bereits LangChain verwenden und ein visuelles Prototyping-Tool möchten. Weniger geeignet für nicht-technische Nutzer oder Teams, die ein ausgereiftes Endprodukt benötigen.
      </div>
    </div>
  </section>

  <!-- OpenWebUI -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">OpenWebUI — Das ChatGPT-Interface für lokale Modelle</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.25rem;">
        OpenWebUI ist ein funktionsreiches, selbst gehostetes Chat-Interface für lokale LLMs. Wenn dein Ziel einfach darin besteht, Ollama oder andere lokale Modelle mit einer polierten ChatGPT-ähnlichen Oberfläche zu betreiben, ist OpenWebUI die beste Option. Aber es ist kein App-Builder — es ist ein Chat-Client.
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#14532d;margin-bottom:0.5rem;">OpenWebUI Stärken</h3>
          <ul style="color:#166534;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>60k+ GitHub-Sterne — riesige Community</li>
            <li>Schönes ChatGPT-ähnliches Interface</li>
            <li>Funktioniert mit Ollama, OpenAI und jeder OpenAI-kompatiblen API</li>
            <li>Multi-User, Rollen und Modellwechsel integriert</li>
          </ul>
        </div>
        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.9rem;font-weight:700;color:#7f1d1d;margin-bottom:0.5rem;">OpenWebUI Einschränkungen</h3>
          <ul style="color:#991b1b;line-height:2;margin:0;padding-left:1rem;font-size:0.875rem;">
            <li>Kein App-Builder — nur ein Chat-Interface</li>
            <li>Kein visueller Workflow-Editor oder Agent-Builder</li>
            <li>Keine RAG-Pipeline-Verwaltung über Datei-Uploads hinaus</li>
            <li>Kann keine Apps für Endnutzer veröffentlichen oder einbetten</li>
          </ul>
        </div>
      </div>
      <div style="background:#f8fafc;border-radius:0.75rem;padding:1rem;font-size:0.875rem;color:#374151;">
        <strong>Am besten für:</strong> Einzelpersonen oder Teams, die ein privates, selbst gehostetes ChatGPT-Interface für die Interaktion mit lokalen oder Cloud-LLMs möchten. Kein Ersatz für Dify, wenn du Anwendungen bauen musst.
      </div>
    </div>
  </section>

  <!-- Entscheidungsmatrix -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Welches Tool solltest du wählen?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">Nutze diese Entscheidungsmatrix, um schnell das richtige Tool zu finden:</p>
      <div style="display:grid;gap:0.75rem;">
        {[
          { condition: 'Ich möchte einen kundenorientierten KI-Chatbot mit meinen Unternehmensdaten bauen', answer: '→ Dify', reason: 'Bestes RAG, Wissensverwaltung und App-Publishing' },
          { condition: 'Ich möchte einen Geschäftsprozess automatisieren, der 5+ SaaS-Tools verbindet', answer: '→ n8n', reason: 'Beste Integrationen und Workflow-Zuverlässigkeit' },
          { condition: 'Ich möchte ein ChatGPT-Interface für lokale Modelle privat betreiben', answer: '→ OpenWebUI', reason: 'Speziell für diesen Anwendungsfall gebaut' },
          { condition: 'Ich bin Python-Entwickler und prototype LangChain-Pipelines', answer: '→ LangFlow', reason: 'Native LangChain-Unterstützung und Code-Export' },
          { condition: 'Ich bin Einsteiger und möchte den einfachsten LLM-Chatbot', answer: '→ Flowise', reason: 'Einsteigerfreundlichste Oberfläche' },
          { condition: 'Ich brauche produktionsreife KI-Agenten mit Gedächtnis und Tool-Nutzung', answer: '→ Dify', reason: 'Vollständigstes Agenten-Framework' },
          { condition: 'Ich muss KI-Workflows aus Geschäftsereignissen (neue Bestellungen, E-Mails) auslösen', answer: '→ n8n + Dify', reason: 'n8n für Ereignisse, Dify für KI-Logik' },
        ].map((d, i) => (
          <div class="card" style="display:grid;grid-template-columns:1fr auto;gap:1rem;align-items:center;">
            <p style="font-size:0.875rem;color:#374151;margin:0;">{d.condition}</p>
            <div style="text-align:right;min-width:120px;">
              <p style="font-weight:700;color:#1677FF;margin:0;font-size:0.9rem;">{d.answer}</p>
              <p style="font-size:0.75rem;color:#6B7280;margin:0;">{d.reason}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fazit -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Fazit: Warum die meisten Teams Dify wählen</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.25rem;">
        Nach der Bewertung aller Alternativen bleibt Dify die beste All-round-Plattform für Teams, die Produktions-KI-Anwendungen bauen. Hier ist warum:
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:1.5rem;">
        {[
          { title: 'Multi-Modell-Unterstützung', desc: 'OpenAI, Anthropic, Gemini, Mistral, Ollama — Modelle wechseln ohne App-Umbau.' },
          { title: 'Produktionsreifes RAG', desc: 'Nicht nur Datei-Upload — richtige Chunking-Strategien, Hybrid-Suche und Retrieval-Tuning.' },
          { title: 'Vollständiges Agenten-Framework', desc: 'Tool-Nutzung, Web-Browsing, Code-Ausführung und Gedächtnis — alles integriert.' },
          { title: 'Team-Zusammenarbeit', desc: 'User-Management, Workspaces, API-Schlüssel und rollenbasierter Zugriff inklusive.' },
          { title: 'App-Publishing', desc: 'Chatbots in Minuten als teilbare Links oder einbettbare Widgets veröffentlichen.' },
          { title: '90k+ Community', desc: 'Die größte Community aller LLM-App-Plattformen — umfangreiche Plugins und Integrationen.' },
        ].map(f => (
          <div class="card">
            <h3 style="font-size:0.9rem;font-weight:700;color:#111827;margin-bottom:0.4rem;">{f.title}</h3>
            <p style="font-size:0.82rem;color:#6B7280;margin:0;line-height:1.5;">{f.desc}</p>
          </div>
        ))}
      </div>
      <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:0.75rem;padding:1.25rem;">
        <p style="font-weight:700;color:#1e40af;margin:0 0 0.5rem;">Fazit</p>
