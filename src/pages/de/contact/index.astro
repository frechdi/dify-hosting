---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/contact/');
---

<BaseLayout
  title="Kontakt — Dify Hosting"
  description="Kontaktieren Sie das Dify Hosting Team. Fragen, Korrekturen oder Partnerschaftsanfragen."
  lang="de"
  canonical="https://dify-hosting.com/de/contact/"
  hreflang={hreflang}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Startseite', href: '/de/' },
        { label: 'Kontakt' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Kontaktieren Sie uns
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:640px;line-height:1.7;">
        Fragen, Korrekturen oder Partnerschaftsanfragen — wir antworten in der Regel innerhalb von 24 Stunden.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;gap:2rem;grid-template-columns:1fr 1fr;align-items:start;">

        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.25rem;font-weight:700;color:#111827;margin-bottom:1.5rem;">Nachricht senden</h2>
          <form style="display:flex;flex-direction:column;gap:1rem;" onsubmit="return false;">
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-name" style="font-size:0.875rem;font-weight:600;color:#374151;">Name</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Ihr Name"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-email" style="font-size:0.875rem;font-weight:600;color:#374151;">E-Mail</label>
              <input
                id="contact-email"
                type="email"
                placeholder="sie@beispiel.com"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-message" style="font-size:0.875rem;font-weight:600;color:#374151;">Nachricht</label>
              <textarea
                id="contact-message"
                rows="5"
                placeholder="Ihre Nachricht..."
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              ></textarea>
            </div>
            <div>
              <button type="submit" class="btn-primary">Nachricht senden</button>
            </div>
          </form>
        </div>

        <div style="display:flex;flex-direction:column;gap:1.5rem;">
          <div class="card" style="padding:1.5rem;">
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">E-Mail</h3>
            <p style="color:#4B5563;margin:0;">
              <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;text-decoration:none;">contact@dify-hosting.com</a>
            </p>
          </div>

          <div class="card" style="padding:1.5rem;">
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Antwortzeit</h3>
            <p style="color:#4B5563;margin:0;font-size:0.9rem;line-height:1.6;">Wir antworten an Werktagen in der Regel innerhalb von 24 Stunden.</p>
          </div>

          <div class="card" style="padding:1.5rem;">
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Häufige Themen</h3>
            <ul style="color:#4B5563;font-size:0.875rem;line-height:2;margin:0;padding-left:1.25rem;">
              <li>Korrekturen zu Anbieter-Bewertungen</li>
              <li>Vorschläge für neue Anbieter</li>
              <li>Anfragen für Affiliate-Partnerschaften</li>
              <li>Technische Fragen zu Dify</li>
              <li>Datenschutz- oder Datenlöschungsanfragen</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
