---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/best-dify-hosting/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Beste Dify Hosting Anbieter 2026',
  description: 'Die 8 besten Hosting-Anbieter für selbstgehostetes Dify AI, getestet und bewertet.',
  numberOfItems: 8,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Hetzner', url: 'https://dify-hosting.com/de/providers/hetzner/' },
    { '@type': 'ListItem', position: 2, name: 'Hostinger', url: 'https://dify-hosting.com/de/providers/hostinger/' },
    { '@type': 'ListItem', position: 3, name: 'DigitalOcean', url: 'https://dify-hosting.com/de/providers/digitalocean/' },
    { '@type': 'ListItem', position: 4, name: 'Vultr', url: 'https://dify-hosting.com/de/providers/vultr/' },
    { '@type': 'ListItem', position: 5, name: 'Elestio', url: 'https://dify-hosting.com/de/providers/elestio/' },
    { '@type': 'ListItem', position: 6, name: 'Railway', url: 'https://dify-hosting.com/de/providers/railway/' },
    { '@type': 'ListItem', position: 7, name: 'Render', url: 'https://dify-hosting.com/de/providers/render/' },
    { '@type': 'ListItem', position: 8, name: 'Kamatera', url: 'https://dify-hosting.com/de/providers/kamatera/' },
  ],
};

const providers = [
  { rank: 1, name: 'Hetzner', price: '€3,79/Mon.', ram: '4GB', vcpu: '2 vCPU', storage: '40GB NVMe', locations: 'EU (DE/FI)', ease: 3, rating: 4.8, badge: 'Bestes Preis-Leistungs-Verhältnis', badgeClass: 'badge-editors-choice', href: '/de/providers/hetzner/' },
  { rank: 2, name: 'Hostinger', price: '$7,99/Mon.', ram: '8GB', vcpu: '2 vCPU', storage: '50GB NVMe', locations: 'Global', ease: 4, rating: 4.5, badge: 'Ideal für Anfänger', badgeClass: 'badge-primary', href: '/de/providers/hostinger/' },
  { rank: 3, name: 'DigitalOcean', price: '$24/Mon.', ram: '4GB', vcpu: '2 vCPU', storage: '80GB SSD', locations: '15 Regionen', ease: 4, rating: 4.3, badge: 'Entwicklerfreundlich', badgeClass: 'badge-primary', href: '/de/providers/digitalocean/' },
  { rank: 4, name: 'Vultr', price: '$12/Mon.', ram: '4GB', vcpu: '2 vCPU', storage: '65GB NVMe', locations: '32 Standorte', ease: 3, rating: 4.2, badge: null, badgeClass: null, href: '/de/providers/vultr/' },
  { rank: 5, name: 'Elestio', price: '$19/Mon.', ram: 'Verwaltet', vcpu: 'Verwaltet', storage: 'Verwaltet', locations: 'Global', ease: 5, rating: 4.0, badge: 'Einfachstes Setup', badgeClass: 'badge-success', href: '/de/providers/elestio/' },
  { rank: 6, name: 'Railway', price: '$5/Mon.', ram: '512MB–8GB', vcpu: 'Geteilt', storage: 'Ephemeral', locations: 'Verwaltet', ease: 5, rating: 3.8, badge: null, badgeClass: null, href: '/de/providers/railway/' },
  { rank: 7, name: 'Render', price: '$25/Mon.', ram: '2GB', vcpu: 'Geteilt', storage: '—', locations: 'US/EU', ease: 4, rating: 3.7, badge: null, badgeClass: null, href: '/de/providers/render/' },
  { rank: 8, name: 'Kamatera', price: '$4/Mon.*', ram: 'Konfig.', vcpu: 'Konfig.', storage: '20GB+', locations: '13 Standorte', ease: 2, rating: 3.9, badge: null, badgeClass: null, href: '/de/providers/kamatera/' },
];

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const hasHalf = rating % 1 >= 0.5;
  const empty = 5 - full - (hasHalf ? 1 : 0);
  return { full, hasHalf, empty };
}

function rankClass(rank: number) {
  if (rank === 1) return 'rank-badge rank-1';
  if (rank === 2) return 'rank-badge rank-2';
  if (rank === 3) return 'rank-badge rank-3';
  return 'rank-badge rank-other';
}
---

<BaseLayout
  title="Bestes Dify Hosting 2026 — Anbieter im Vergleich"
  description="Wir haben 8 Hosting-Anbieter für Dify AI getestet. Vergleich von Preisen, Leistung und Setup-Aufwand. Hetzner gewinnt beim Preis-Leistungs-Verhältnis."
  lang="de"
  canonical="https://dify-hosting.com/de/best-dify-hosting/"
  hreflang={hreflang}
  schema={schema}
>
  <!-- Hero -->
  <section class="hero-gradient section" style="padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Startseite', href: '/de/' },
        { label: 'Bestes Dify Hosting' },
      ]} />
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span class="badge badge-success">Zuletzt aktualisiert: März 2026</span>
        <span class="badge badge-primary">8 Anbieter getestet</span>
      </div>
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#111827;line-height:1.2;margin-bottom:1rem;">
        Bestes Dify Hosting 2026 — Anbieter im Vergleich
      </h1>
      <p style="font-size:1.15rem;color:#4B5563;max-width:680px;line-height:1.7;margin-bottom:1.5rem;">
