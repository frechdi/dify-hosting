---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/about/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Über Dify Hosting — Unsere Mission & Bewertungsmethodik',
  description: 'Erfahren Sie mehr über die redaktionelle Mission von Dify Hosting, wie wir Anbieter testen, unsere Affiliate-Offenlegung und wie Sie uns kontaktieren können.',
  url: 'https://dify-hosting.com/de/about/',
  publisher: {
    '@type': 'Organization',
    name: 'Dify Hosting',
    url: 'https://dify-hosting.com',
  },
};

const methodology = [
  { step: '1', label: 'Echtes Konto bei jedem Anbieter erstellen' },
  { step: '2', label: 'Dify mit Docker Compose deployen' },
  { step: '3', label: 'Standardisierte Tests über 30 Tage durchführen (Antwortzeit, Uptime, Ressourcennutzung)' },
  { step: '4', label: 'Support-Qualität bewerten' },
  { step: '5', label: 'Tatsächliche Gesamtbetriebskosten berechnen' },
];

const testMetrics = [
  'Setup-Zeit (Minuten vom ersten Login bis zum laufenden Dify)',
  'Zeit bis zur ersten Antwort innerhalb von Dify',
  'CPU- und RAM-Nutzung unter simulierter Last',
  'Speicher-I/O-Geschwindigkeit',
  'Netzwerklatenz aus wichtigen Regionen',
  'Abrechnungsgenauigkeit',
];
---

<BaseLayout
  title="Über Dify Hosting — Unsere Mission & Bewertungsmethodik"
  description="Erfahren Sie mehr über die redaktionelle Mission von Dify Hosting, wie wir Anbieter testen, unsere Affiliate-Offenlegung und wie Sie uns kontaktieren können."
  lang="de"
  canonical="https://dify-hosting.com/de/about/"
  hreflang={hreflang}
  schema={schema}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Startseite', href: '/de/' },
        { label: 'Über uns' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Über Dify Hosting
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:640px;line-height:1.7;">
        Unsere Mission, Bewertungsmethodik und redaktionellen Standards — damit Sie genau wissen, wie wir zu unseren Empfehlungen gelangen.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;gap:2.5rem;">

        <!-- Wer wir sind -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Wer wir sind</h2>
          <div class="prose">
            <p>
              Dify Hosting ist eine unabhängige Vergleichsseite für Dify-Self-Hosting-Anbieter. Wir testen jeden Anbieter, indem wir Dify tatsächlich auf deren Infrastruktur deployen und Leistung, Setup-Zeit und Preis-Leistungs-Verhältnis messen.
            </p>
            <p>
              Wir sind ein kleines Team aus Entwicklern und Cloud-Ingenieuren, die Dify seit 2023 im Produktivbetrieb nutzen. Wir haben diese Seite erstellt, weil wir keinen ehrlichen, praxisnahen Vergleich der verfügbaren Hosting-Optionen finden konnten — also haben wir selbst einen erstellt.
            </p>
          </div>
        </div>

        <!-- Methodik -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Unsere Bewertungsmethodik</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Jedes Anbieter-Ranking auf dieser Seite ist das Ergebnis eines standardisierten Testprozesses:
          </p>
          <ol style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.875rem;">
            {methodology.map((item) => (
              <li style="display:flex;align-items:flex-start;gap:1rem;">
                <span style="flex-shrink:0;width:2rem;height:2rem;border-radius:50%;background:#1677FF;color:#fff;font-weight:700;font-size:0.875rem;display:flex;align-items:center;justify-content:center;">
                  {item.step}
                </span>
                <span style="color:#374151;line-height:1.6;padding-top:0.25rem;">{item.label}</span>
              </li>
            ))}
          </ol>
        </div>

        <!-- Was wir messen -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Was wir messen</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.25rem;">
            Unsere Benchmark-Suite deckt die Metriken ab, die für ein Dify-Deployment am wichtigsten sind:
          </p>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            {testMetrics.map((metric) => (
              <li style="display:flex;align-items:flex-start;gap:0.75rem;color:#374151;line-height:1.6;">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-top:0.2rem;">
                  <circle cx="9" cy="9" r="9" fill="#dcfce7"/>
                  <path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="#16a34a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {metric}
              </li>
            ))}
          </ul>
        </div>

        <!-- Affiliate-Offenlegung -->
        <div class="card" style="padding:2rem;border-left:4px solid #f59e0b;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Affiliate-Offenlegung</h2>
          <div class="prose">
            <p>
              Diese Seite verdient Provisionen über Affiliate-Links, wenn Sie durchklicken und sich bei einem Hosting-Anbieter registrieren. So finanzieren wir die laufenden Tests und die Pflege dieser Seite.
            </p>
            <p>
              Wir empfehlen nur Anbieter, die wir persönlich getestet haben und selbst nutzen würden. Unsere Rankings basieren auf Verdienst — Leistung, Preis-Leistungs-Verhältnis und Zuverlässigkeit — nicht auf Provisionssätzen. Anbieter zahlen niemals dafür, in unseren Rankings zu erscheinen oder eine höhere Platzierung zu erhalten.
            </p>
          </div>
        </div>

        <!-- Kontakt -->
        <div class="card" style="padding:2rem;" id="contact">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Kontaktieren Sie uns</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Nutzen Sie das Formular unten oder schreiben Sie uns eine E-Mail an <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;text-decoration:none;">contact@dify-hosting.com</a>. Wir antworten in der Regel innerhalb von 24 Stunden.
          </p>
          <form style="display:flex;flex-direction:column;gap:1rem;" onsubmit="return false;">
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-name" style="font-size:0.875rem;font-weight:600;color:#374151;">Name</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Ihr Name"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-email" style="font-size:0.875rem;font-weight:600;color:#374151;">E-Mail</label>
              <input
                id="contact-email"
                type="email"
                placeholder="sie@beispiel.com"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-message" style="font-size:0.875rem;font-weight:600;color:#374151;">Nachricht</label>
              <textarea
                id="contact-message"
                rows="5"
                placeholder="Ihre Nachricht..."
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              ></textarea>
            </div>
            <div>
              <button type="submit" class="btn-primary">Nachricht senden</button>
            </div>
          </form>
        </div>

        <!-- Weiterführende Links -->
        <div style="padding:1.5rem;background:#f8fafc;border-radius:1rem;border:1px solid #e2e8f0;">
          <p style="font-weight:600;color:#374151;margin-bottom:0.875rem;">Unsere Recherchen erkunden:</p>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/de/best-dify-hosting/" class="btn-primary" style="text-decoration:none;">Beste Dify Hosting Anbieter</a>
            <a href="/de/faq/" class="btn-secondary" style="text-decoration:none;">Dify FAQ</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
