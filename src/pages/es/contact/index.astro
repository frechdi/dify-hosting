---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/contact/');
---

<BaseLayout
  title="Contacto — Dify Hosting"
  description="Contacta al equipo de Dify Hosting. Preguntas, correcciones o consultas de colaboración."
  lang="es"
  canonical="https://dify-hosting.com/es/contact/"
  hreflang={hreflang}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/es/' },
        { label: 'Contacto' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Contáctanos
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:640px;line-height:1.7;">
        Preguntas, correcciones o consultas de colaboración — normalmente respondemos en menos de 24 horas.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;gap:2rem;grid-template-columns:1fr 1fr;align-items:start;">

        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.25rem;font-weight:700;color:#111827;margin-bottom:1.5rem;">Enviar un mensaje</h2>
          <form style="display:flex;flex-direction:column;gap:1rem;" onsubmit="return false;">
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-name" style="font-size:0.875rem;font-weight:600;color:#374151;">Nombre</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Tu nombre"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-email" style="font-size:0.875rem;font-weight:600;color:#374151;">Correo electrónico</label>
              <input
                id="contact-email"
                type="email"
                placeholder="tu@ejemplo.com"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-message" style="font-size:0.875rem;font-weight:600;color:#374151;">Mensaje</label>
              <textarea
                id="contact-message"
                rows="5"
                placeholder="Tu mensaje..."
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              ></textarea>
            </div>
            <div>
              <button type="submit" class="btn-primary">Enviar mensaje</button>
            </div>
          </form>
        </div>

        <div style="display:flex;flex-direction:column;gap:1.5rem;">
          <div class="card" style="padding:1.5rem;">
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Correo electrónico</h3>
            <p style="color:#4B5563;margin:0;">
              <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;text-decoration:none;">contact@dify-hosting.com</a>
            </p>
          </div>

          <div class="card" style="padding:1.5rem;">
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Tiempo de respuesta</h3>
            <p style="color:#4B5563;margin:0;font-size:0.9rem;line-height:1.6;">Normalmente respondemos en menos de 24 horas en días laborables.</p>
          </div>

          <div class="card" style="padding:1.5rem;">
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Temas frecuentes</h3>
            <ul style="color:#4B5563;font-size:0.875rem;line-height:2;margin:0;padding-left:1.25rem;">
              <li>Correcciones en reseñas de proveedores</li>
              <li>Sugerencias de nuevos proveedores</li>
              <li>Consultas de colaboración de afiliados</li>
              <li>Preguntas técnicas sobre Dify</li>
              <li>Solicitudes de privacidad o eliminación de datos</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
