---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getHreflang } from '../../i18n/hreflang';
import { getHomepageContent } from '../../i18n/homepage';

const lang = 'es';
const t = getHomepageContent(lang);
const hreflang = getHreflang('/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dify Hosting',
  url: 'https://dify-hosting.com',
  description: t.meta.description,
};

const providers = [
  { rank: 1, name: 'Hetzner', price: '€3.79/mo', ram: '4GB', badge: 'Best Value', href: `/es/providers/hetzner/`, logo: '/logos/hetzner-logo.svg' },
  { rank: 2, name: 'Hostinger', price: '$7.99/mo', ram: '8GB', badge: 'Best for Beginners', href: `/es/providers/hostinger/`, logo: '/logos/hostinger-logo.svg' },
  { rank: 3, name: 'DigitalOcean', price: '$24/mo', ram: '4GB', badge: 'Developer Friendly', href: `/es/providers/digitalocean/`, logo: '/logos/digitalocean-logo.svg' },
  { rank: 4, name: 'Vultr', price: '$12/mo', ram: '4GB', badge: null, href: `/es/providers/vultr/`, logo: '/logos/vultr-logo.svg' },
  { rank: 5, name: 'Elestio', price: '$15/mo', ram: '2GB', badge: 'Managed', href: `/es/providers/elestio/`, logo: '/logos/elestio-logo.svg' },
  { rank: 6, name: 'Railway', price: 'Pay-as-you-go', ram: '8GB', badge: null, href: `/es/providers/railway/`, logo: '/logos/railway-logo.svg' },
  { rank: 7, name: 'Render', price: 'Free–$25/mo', ram: '512MB–4GB', badge: null, href: `/es/providers/render/`, logo: '/logos/render-logo.svg' },
  { rank: 8, name: 'Kamatera', price: '$4/mo', ram: '1GB+', badge: null, href: `/es/providers/kamatera/`, logo: '/logos/kamatera-logo.svg' },
];
---

<BaseLayout
  title={t.meta.title}
  description={t.meta.description}
  lang={lang}
  canonical="https://dify-hosting.com/es/"
  hreflang={hreflang}
  schema={schema}
>
  <!-- Hero -->
  <section style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%);padding:5rem 1rem 4rem;text-align:center;">
    <div style="max-width:800px;margin:0 auto;">
      <span style="display:inline-block;background:rgba(99,102,241,0.15);color:#a5b4fc;border:1px solid rgba(99,102,241,0.3);border-radius:2rem;padding:0.375rem 1rem;font-size:0.8125rem;font-weight:600;letter-spacing:0.05em;margin-bottom:1.5rem;">
        {t.hero.badge}
      </span>
      <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:900;color:#f8fafc;line-height:1.15;margin-bottom:1.25rem;">
        {t.hero.h1}
      </h1>
      <p style="font-size:1.125rem;color:#94a3b8;line-height:1.7;margin-bottom:2.5rem;max-width:640px;margin-left:auto;margin-right:auto;">
        {t.hero.subtitle}
      </p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem;">
        <a href={`/es/best-dify-hosting/`} class="btn-primary" style="text-decoration:none;font-size:1rem;padding:0.875rem 2rem;">
          {t.hero.ctaPrimary}
        </a>
        <a href={`/es/guides/self-host-dify/`} class="btn-secondary" style="text-decoration:none;font-size:1rem;padding:0.875rem 2rem;color:#cbd5e1;border-color:#475569;">
          {t.hero.ctaSecondary}
        </a>
      </div>
      <div style="display:flex;gap:2.5rem;justify-content:center;flex-wrap:wrap;">
        {t.hero.stats.map(s => (
          <div style="text-align:center;">
            <div style="font-size:1.75rem;font-weight:800;color:#f8fafc;">{s.value}</div>
            <div style="font-size:0.8125rem;color:#64748b;font-weight:500;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div style="background:#1e293b;border-top:1px solid #334155;border-bottom:1px solid #334155;padding:0.875rem 1rem;">
    <div style="max-width:900px;margin:0 auto;display:flex;gap:1.5rem;justify-content:center;flex-wrap:wrap;">
      {t.trustBar.items.map(item => (
        <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.8125rem;color:#94a3b8;font-weight:500;">
          <span style="color:#4ade80;">{item.icon}</span>{item.text}
        </span>
      ))}
    </div>
  </div>

  <!-- Providers -->
  <section class="section section-alt">
    <div class="container">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <span class="badge badge-primary" style="margin-bottom:0.75rem;">{t.providersSection.badge}</span>
        <h2 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#111827;margin-bottom:0.75rem;">{t.providersSection.h2}</h2>
        <p style="color:#6b7280;max-width:560px;margin:0 auto;line-height:1.6;">{t.providersSection.subtitle}</p>
      </div>
      <div style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));">
        {providers.map(p => (
          <a href={p.href} style="text-decoration:none;display:flex;flex-direction:column;gap:0.75rem;background:#fff;border:1px solid #e5e7eb;border-radius:0.875rem;padding:1.25rem 1.5rem;transition:box-shadow 0.2s,border-color 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.08)';this.style.borderColor='#6366f1'" onmouseout="this.style.boxShadow='none';this.style.borderColor='#e5e7eb'">
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <img src={p.logo} alt={p.name + ' logo'} width="24" height="24" style="object-fit:contain;" />
              {p.badge && <span style="font-size:0.6875rem;font-weight:700;background:#ede9fe;color:#6d28d9;border-radius:0.375rem;padding:0.25rem 0.625rem;">{p.badge}</span>}
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;">
              <span style="font-size:0.75rem;font-weight:700;color:#94a3b8;">#{p.rank}</span>
              <span style="font-size:1rem;font-weight:700;color:#111827;">{p.name}</span>
            </div>
            <div style="display:flex;gap:1rem;">
              <span style="font-size:0.8125rem;color:#4b5563;"><strong style="color:#111827;">{p.price}</strong></span>
              <span style="font-size:0.8125rem;color:#4b5563;">{p.ram} RAM</span>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/es/best-dify-hosting/" class="btn-primary" style="text-decoration:none;">See Full Comparison →</a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container-sm">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <span class="badge badge-primary" style="margin-bottom:0.75rem;">{t.howItWorks.badge}</span>
        <h2 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#111827;margin-bottom:0.75rem;">{t.howItWorks.h2}</h2>
        <p style="color:#6b7280;max-width:500px;margin:0 auto;line-height:1.6;">{t.howItWorks.subtitle}</p>
      </div>
      <div style="display:grid;gap:1.5rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
        {t.howItWorks.steps.map((step, i) => (
          <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.875rem;padding:1.75rem 1.5rem;">
            <div style="width:2.5rem;height:2.5rem;border-radius:50%;background:#6366f1;color:#fff;font-weight:800;font-size:1rem;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">{i+1}</div>
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">{step.title}</h3>
            <p style="font-size:0.875rem;color:#6b7280;line-height:1.6;margin:0;">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="container-sm">
      <div style="text-align:center;margin-bottom:2rem;">
        <span class="badge badge-primary" style="margin-bottom:0.75rem;">{t.faqSection.badge}</span>
        <h2 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#111827;">{t.faqSection.h2}</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        {t.faqSection.items.map((item, i) => (
          <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.75rem;overflow:hidden;">
            <button onclick={`document.getElementById('faq-${i}').style.display=document.getElementById('faq-${i}').style.display==='none'?'block':'none'`} style="width:100%;text-align:left;padding:1.25rem 1.5rem;background:none;border:none;cursor:pointer;font-size:0.9375rem;font-weight:600;color:#111827;display:flex;justify-content:space-between;align-items:center;gap:1rem;">
              {item.q}
              <span style="flex-shrink:0;color:#6366f1;">+</span>
            </button>
            <div id={`faq-${i}`} style="display:none;padding:0 1.5rem 1.25rem;">
              <p style="color:#4b5563;line-height:1.7;margin:0;font-size:0.9375rem;">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 100%);padding:4rem 1rem;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#fff;margin-bottom:1rem;">{t.ctaSection.h2}</h2>
      <p style="color:#c7d2fe;line-height:1.7;margin-bottom:2rem;">{t.ctaSection.subtitle}</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/es/providers/hostinger/" class="btn-primary" style="text-decoration:none;background:#fff;color:#4f46e5;border-color:#fff;">
          {t.ctaSection.btnPrimary}
        </a>
        <a href="/es/guides/self-host-dify/" style="text-decoration:none;color:#e0e7ff;font-weight:600;display:flex;align-items:center;gap:0.4rem;">
          {t.ctaSection.btnSecondary} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
