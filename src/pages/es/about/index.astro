---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/about/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Sobre Dify Hosting — Nuestra Misión y Metodología de Análisis',
  description: 'Conoce la misión editorial de Dify Hosting, cómo evaluamos los proveedores, nuestra política de afiliados y cómo contactarnos.',
  url: 'https://dify-hosting.com/es/about/',
  publisher: {
    '@type': 'Organization',
    name: 'Dify Hosting',
    url: 'https://dify-hosting.com',
  },
};

const methodology = [
  { step: '1', label: 'Crear una cuenta real con cada proveedor' },
  { step: '2', label: 'Desplegar Dify usando Docker Compose' },
  { step: '3', label: 'Ejecutar pruebas estandarizadas durante 30 días (tiempo de respuesta, disponibilidad, uso de recursos)' },
  { step: '4', label: 'Evaluar la calidad del soporte técnico' },
  { step: '5', label: 'Calcular el coste total de propiedad' },
];

const testMetrics = [
  'Tiempo de configuración (minutos desde el primer inicio de sesión hasta tener Dify funcionando)',
  'Tiempo hasta la primera respuesta dentro de Dify',
  'Uso de CPU y RAM bajo carga simulada',
  'Velocidad de I/O de almacenamiento',
  'Latencia de red desde regiones clave',
  'Precisión de facturación',
];
---

<BaseLayout
  title="Sobre Dify Hosting — Nuestra Misión y Metodología de Análisis"
  description="Conoce la misión editorial de Dify Hosting, cómo evaluamos los proveedores, nuestra política de afiliados y cómo contactarnos."
  lang="es"
  canonical="https://dify-hosting.com/es/about/"
  hreflang={hreflang}
  schema={schema}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/es/' },
        { label: 'Sobre nosotros' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Sobre Dify Hosting
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:640px;line-height:1.7;">
        Nuestra misión, metodología de análisis y estándares editoriales — para que sepas exactamente cómo llegamos a nuestras recomendaciones.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;gap:2.5rem;">

        <!-- Quiénes somos -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Quiénes Somos</h2>
          <div class="prose">
            <p>
              Dify Hosting es un sitio de comparación independiente de proveedores de alojamiento para Dify. Probamos cada proveedor desplegando Dify realmente en su infraestructura y midiendo el rendimiento, el tiempo de configuración y la relación calidad-precio.
            </p>
            <p>
              Somos un pequeño equipo de desarrolladores e ingenieros de nube que llevamos ejecutando Dify en producción desde 2023. Creamos este sitio porque no encontramos una comparación honesta y práctica de las opciones de alojamiento disponibles — así que la hicimos nosotros mismos.
            </p>
          </div>
        </div>

        <!-- Metodología -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Nuestra Metodología de Análisis</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Cada clasificación de proveedores en este sitio es el resultado de un proceso de prueba estandarizado:
          </p>
          <ol style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.875rem;">
            {methodology.map((item) => (
              <li style="display:flex;align-items:flex-start;gap:1rem;">
                <span style="flex-shrink:0;width:2rem;height:2rem;border-radius:50%;background:#1677FF;color:#fff;font-weight:700;font-size:0.875rem;display:flex;align-items:center;justify-content:center;">
                  {item.step}
                </span>
                <span style="color:#374151;line-height:1.6;padding-top:0.25rem;">{item.label}</span>
              </li>
            ))}
          </ol>
        </div>

        <!-- Qué medimos -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Qué Medimos</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.25rem;">
            Nuestra suite de benchmarks cubre las métricas más importantes para un despliegue de Dify:
          </p>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            {testMetrics.map((metric) => (
              <li style="display:flex;align-items:flex-start;gap:0.75rem;color:#374151;line-height:1.6;">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-top:0.2rem;">
                  <circle cx="9" cy="9" r="9" fill="#dcfce7"/>
                  <path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="#16a34a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {metric}
              </li>
            ))}
          </ul>
        </div>

        <!-- Divulgación de afiliados -->
        <div class="card" style="padding:2rem;border-left:4px solid #f59e0b;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Divulgación de Afiliados</h2>
          <div class="prose">
            <p>
              Este sitio obtiene comisiones a través de enlaces de afiliados cuando haces clic y te registras con un proveedor de alojamiento. Así es como financiamos las pruebas continuas y el mantenimiento de este sitio.
            </p>
            <p>
              Solo recomendamos proveedores que hemos probado personalmente y que usaríamos nosotros mismos. Nuestras clasificaciones se basan en méritos — rendimiento, valor y fiabilidad — no en las tasas de comisión. Los proveedores nunca pagan para aparecer en nuestras clasificaciones ni para obtener una posición más alta.
            </p>
          </div>
        </div>

        <!-- Contacto -->
        <div class="card" style="padding:2rem;" id="contact">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Contacto</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Usa el formulario a continuación o envíanos un correo a <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;text-decoration:none;">contact@dify-hosting.com</a>. Normalmente respondemos en 24 horas.
          </p>
          <form style="display:flex;flex-direction:column;gap:1rem;" onsubmit="return false;">
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-name" style="font-size:0.875rem;font-weight:600;color:#374151;">Nombre</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Tu nombre"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-email" style="font-size:0.875rem;font-weight:600;color:#374151;">Correo electrónico</label>
              <input
                id="contact-email"
                type="email"
                placeholder="tu@ejemplo.com"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-message" style="font-size:0.875rem;font-weight:600;color:#374151;">Mensaje</label>
              <textarea
                id="contact-message"
                rows="5"
                placeholder="Tu mensaje..."
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              ></textarea>
            </div>
            <div>
              <button type="submit" class="btn-primary">Enviar Mensaje</button>
            </div>
          </form>
        </div>

        <!-- Enlaces relacionados -->
        <div style="padding:1.5rem;background:#f8fafc;border-radius:1rem;border:1px solid #e2e8f0;">
          <p style="font-weight:600;color:#374151;margin-bottom:0.875rem;">Explora nuestra investigación:</p>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/es/best-dify-hosting/" class="btn-primary" style="text-decoration:none;">Mejores Proveedores de Hosting para Dify</a>
            <a href="/es/faq/" class="btn-secondary" style="text-decoration:none;">Preguntas Frecuentes sobre Dify</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
