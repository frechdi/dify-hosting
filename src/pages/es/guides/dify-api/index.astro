---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../../i18n/hreflang';

const hreflang = getHreflang('/guides/dify-api/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Guía API Dify 2026: Integra IA en tu app con REST',
  description: 'Guía completa de la API Dify. Autenticación, endpoints de chat, streaming e integración de la IA de Dify en cualquier app via REST. Ejemplos con curl y Python incluidos.',
  datePublished: '2026-01-01',
  dateModified: '2026-03-24',
  author: { '@type': 'Organization', name: 'Dify Hosting' },
};

const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"¿Cómo obtengo una clave API de Dify?","acceptedAnswer":{"@type":"Answer","text":"Abre tu app de Dify, haz clic en 'API Access' en la esquina superior derecha, y crea una nueva clave API. Copia la clave secreta — no se mostrará de nuevo. Úsala en el header Authorization como 'Bearer TU_CLAVE'."}},{"@type":"Question","name":"¿Es gratuita la API de Dify?","acceptedAnswer":{"@type":"Answer","text":"La API de Dify en sí es gratuita — solo pagas por los tokens LLM consumidos (OpenAI, Anthropic, etc.). Dify auto-hospedado no tiene cargos por llamada. Dify Cloud cobra según créditos de mensajes."}},{"@type":"Question","name":"¿Puedo hacer streaming de respuestas de la API Dify?","acceptedAnswer":{"@type":"Answer","text":"Sí. Establece 'response_mode':'streaming' en el cuerpo de la solicitud para recibir Server-Sent Events (SSE). Esto muestra los tokens a medida que se generan, como el efecto de escritura de ChatGPT."}},{"@type":"Question","name":"¿Qué lenguajes de programación funcionan con la API Dify?","acceptedAnswer":{"@type":"Answer","text":"Cualquier lenguaje que soporte solicitudes HTTP: Python, JavaScript/Node.js, PHP, Ruby, Go, Java, C# y más. Dify ofrece SDKs oficiales para Python y Node.js, más ejemplos curl para cada endpoint."}}]};
---

<BaseLayout
  title="Guía API Dify 2026: Integra IA en tu app con REST"
  description="Guía completa de la API Dify. Autenticación, endpoints de chat, streaming e integración de la IA de Dify en cualquier app via REST. Ejemplos con curl y Python incluidos."
  lang="es"
  canonical="https://dify-hosting.com/es/guides/dify-api/"
  hreflang={hreflang}
  schema={[schema, faqSchema]}
>
  <!-- Hero -->
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/es/' },
        { label: 'Guías', href: '/es/guides/' },
        { label: 'Guía API Dify' },
      ]} />
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#dcfce7;color:#166534;">Actualizado marzo 2026</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#fef9c3;color:#713f12;">Guía para Desarrolladores</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#ede9fe;color:#4c1d95;">REST API</span>
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:#fff;line-height:1.2;margin-bottom:1rem;">
        Guía API Dify 2026: Integra IA en tu app con REST
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:680px;line-height:1.7;">
        La API REST de Dify te permite llamar cualquier app de Dify desde tu propio código — integrar un chatbot en tu sitio web, automatizar el procesamiento de documentos o añadir funciones de IA a cualquier producto SaaS. Esta guía cubre todo, desde obtener tu clave API hasta hacer streaming de respuestas y configuraciones auto-hospedadas.
      </p>
    </div>
  </section>

  <!-- Section 1: ¿Qué es la API Dify? -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">¿Qué es la API Dify?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        La API Dify es una API REST que te permite llamar programáticamente cualquier app creada en Dify — desde cualquier lenguaje de programación o plataforma. Una vez que publicas una app de Dify (chatbot, agente, workflow o app de completado), obtiene su propio endpoint API que puedes llamar con una clave secreta.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        La URL base para Dify Cloud es <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;font-size:0.875rem;">https://api.dify.ai/v1</code>. Si auto-hospedas Dify, reemplázala con tu propio dominio: <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;font-size:0.875rem;">https://tu-servidor.com/v1</code>.
      </p>
      <h3 style="font-size:1.1rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Casos de uso comunes</h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.75rem;margin-bottom:1.5rem;">
        {[
          { title: 'Chatbot en tu web', desc: 'Integrar chat IA en cualquier sitio sin usar el widget de Dify.' },
          { title: 'Automatización documental', desc: 'Enviar PDFs o texto a un workflow de Dify y recibir salida estructurada.' },
          { title: 'Funciones IA en SaaS', desc: 'Añadir escritura IA, resúmenes o Q&A a tu producto existente.' },
          { title: 'Pipelines backend', desc: 'Disparar agentes Dify desde cron jobs, webhooks o procesadores de cola.' },
          { title: 'Apps móviles', desc: 'Llamar a Dify desde apps iOS o Android mediante HTTP estándar.' },
          { title: 'Herramientas no-code', desc: 'Conectar Dify a n8n, Make o Zapier mediante nodos de solicitud HTTP.' },
        ].map(u => (
          <div style="background:#f8fafc;border-radius:0.5rem;padding:0.875rem;border-left:3px solid #1677FF;">
            <p style="font-weight:700;font-size:0.875rem;color:#111827;margin:0 0 0.3rem;">{u.title}</p>
            <p style="font-size:0.82rem;color:#6B7280;margin:0;line-height:1.5;">{u.desc}</p>
          </div>
        ))}
      </div>
      <div style="background:#f0f9ff;border-left:3px solid #1677FF;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#1e40af;">
        <strong>Nota:</strong> Cada tipo de app Dify (Chatbot, Agente, Workflow, Completado) tiene endpoints ligeramente distintos. Esta guía se centra en la API de Chat Messages, la más utilizada.
      </div>
    </div>
  </section>

  <!-- Section 2: Obtener tu clave API -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Obtener tu clave API</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.25rem;">
        Cada app de Dify tiene su propia clave API. Debes crear una para cada app a la que quieras acceder via API. Así se hace:
      </p>
      <div style="display:grid;gap:0.75rem;max-width:620px;margin-bottom:1.5rem;">
        {[
          { step: '1', action: 'Abre tu app de Dify en Studio', detail: 'Ve a cloud.dify.ai (o tu URL auto-hospedada) y abre la app que quieres llamar via API.' },
          { step: '2', action: 'Haz clic en "API Access" en la esquina superior derecha', detail: 'Esto abre el panel de referencia API para esa app específica.' },
          { step: '3', action: 'Haz clic en "Crear clave API"', detail: 'Dale un nombre (ej. "producción" o "prueba") para identificarla más tarde.' },
          { step: '4', action: 'Copia la clave secreta inmediatamente', detail: 'La clave se muestra solo una vez. Guárdala en tus variables de entorno — nunca la escribas directamente en el código fuente.' },
          { step: '5', action: 'Úsala en el header Authorization', detail: 'Todas las solicitudes API necesitan este header: Authorization: Bearer TU_CLAVE_API' },
        ].map(s => (
          <div style="display:flex;align-items:flex-start;gap:0.75rem;">
            <span style="width:1.75rem;height:1.75rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;flex-shrink:0;margin-top:0.1rem;">{s.step}</span>
            <div>
              <p style="font-weight:700;font-size:0.9rem;color:#111827;margin:0 0 0.2rem;">{s.action}</p>
              <p style="font-size:0.82rem;color:#6B7280;margin:0;line-height:1.5;">{s.detail}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="background:#fef2f2;border-left:3px solid #ef4444;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#991b1b;">
        <strong>Advertencia de seguridad:</strong> Nunca expongas tu clave API en JavaScript del lado del cliente ni la subas a un repositorio público. Guárdala siempre como variable de entorno y realiza las llamadas a la API Dify desde tu servidor backend.
      </div>
    </div>
  </section>

  <!-- Section 3: Endpoints de la API -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Resumen de endpoints de la API</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        La API Dify proporciona endpoints para enviar mensajes, gestionar conversaciones, subir archivos y más. Todos los endpoints son relativos a la URL base <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;font-size:0.875rem;">https://api.dify.ai/v1</code>.
      </p>
      <div style="overflow-x:auto;margin-bottom:1.5rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
          <thead>
            <tr style="background:#f8fafc;">
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:700;color:#374151;border-bottom:2px solid #e5e7eb;">Método</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:700;color:#374151;border-bottom:2px solid #e5e7eb;">Endpoint</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-weight:700;color:#374151;border-bottom:2px solid #e5e7eb;">Descripción</th>
            </tr>
          </thead>
          <tbody>
            {[
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/chat-messages', desc: 'Enviar mensaje de chat y recibir respuesta. Soporta modos blocking y streaming.' },
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/completion-messages', desc: 'Enviar un prompt a una app de completado. Devuelve un texto generado.' },
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/files/upload', desc: 'Subir un archivo (PDF, imagen, etc.) para apps RAG o de visión.' },
              { method: 'GET', color: '#1677FF', bg: '#eff6ff', endpoint: '/conversations', desc: 'Listar todas las conversaciones de un usuario. Usa el parámetro user para filtrar.' },
              { method: 'GET', color: '#1677FF', bg: '#eff6ff', endpoint: '/messages', desc: 'Obtener el historial de mensajes de una conversación específica.' },
              { method: 'DELETE', color: '#dc2626', bg: '#fef2f2', endpoint: '/conversations/:id', desc: 'Eliminar permanentemente una conversación y todos sus mensajes.' },
              { method: 'POST', color: '#16a34a', bg: '#f0fdf4', endpoint: '/messages/:id/feedbacks', desc: 'Enviar una valoración (pulgar arriba/abajo) para un mensaje específico.' },
              { method: 'GET', color: '#1677FF', bg: '#eff6ff', endpoint: '/parameters', desc: 'Obtener los parámetros de entrada, texto de intro y preguntas sugeridas de la app.' },
            ].map(r => (
              <tr style="border-bottom:1px solid #f3f4f6;">
                <td style={`padding:0.75rem 1rem;font-family:monospace;font-size:0.8rem;font-weight:700;color:${r.color};background:${r.bg};white-space:nowrap;`}>{r.method}</td>
                <td style="padding:0.75rem 1rem;font-family:monospace;font-size:0.8rem;color:#374151;white-space:nowrap;">{r.endpoint}</td>
                <td style="padding:0.75rem 1rem;color:#6B7280;line-height:1.5;">{r.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Section 4: Primera llamada API -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Tu primera llamada a la API</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Hagamos una llamada API real. Reemplaza <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">TU_CLAVE_API</code> con tu clave real. El campo <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">user</code> es un identificador único para el usuario final — usa cualquier cadena que lo identifique en tu sistema.
      </p>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Ejemplo con curl</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>curl -X POST 'https://api.dify.ai/v1/chat-messages' \
  -H 'Authorization: Bearer TU_CLAVE_API' \
  -H 'Content-Type: application/json' \
  -d '{"{"}
    "inputs": {"{"}{"}"},
    "query": "¡Hola! ¿En qué puedes ayudarme?",
    "response_mode": "blocking",
    "conversation_id": "",
    "user": "usuario-123"
  {"}"}'</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Ejemplo de respuesta</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>{"{"}
  "event": "message",
  "task_id": "abc123",
  "id": "msg_456",
  "conversation_id": "conv_789",
  "mode": "chat",
  "answer": "¡Hola! Puedo ayudarte con preguntas, escritura, análisis y mucho más. ¿Qué te gustaría explorar?",
  "metadata": {"{"} "usage": {"{"} "prompt_tokens": 12, "completion_tokens": 23 {"}"} {"}"},
  "created_at": 1711234567
{"}"}</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Ejemplo Python (con requests)</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>import requests

API_KEY = "tu_clave_api_aqui"
BASE_URL = "https://api.dify.ai/v1"

def chat(query, conversation_id="", user="usuario-123"):
    response = requests.post(
        f"{"{BASE_URL}"}/chat-messages",
        headers={"{"}
            "Authorization": f"Bearer {"{API_KEY}"}",
            "Content-Type": "application/json",
        {"}"},
        json={"{"}
            "inputs": {"{}"},
            "query": query,
            "response_mode": "blocking",
            "conversation_id": conversation_id,
            "user": user,
        {"}"}
    )
    response.raise_for_status()
    return response.json()

# Primer mensaje
result = chat("¿Qué es Dify?")
print(result["answer"])
conversation_id = result["conversation_id"]

# Seguimiento en la misma conversación
result2 = chat("¿Puedes ampliar eso?", conversation_id=conversation_id)
print(result2["answer"])</code></pre>

      <div style="background:#f0fdf4;border-left:3px solid #16a34a;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#166534;">
        <strong>Consejo:</strong> Guarda el <code>conversation_id</code> de la primera respuesta y pásalo en las llamadas siguientes. Esto mantiene el historial de conversación para que la IA recuerde lo que se ha dicho.
      </div>
    </div>
  </section>

  <!-- Section 5: Streaming -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Respuestas en streaming (SSE)</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        El streaming te permite mostrar tokens a medida que se generan — como el efecto de escritura de ChatGPT. Dify usa Server-Sent Events (SSE) para el streaming. Establece <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">"response_mode": "streaming"</code> en el cuerpo de tu solicitud.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Cada evento llega como una línea con el prefijo <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">data:</code>. Los tipos de evento incluyen <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">message</code> (un chunk de token), <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">message_end</code> (mensaje final con metadatos) y <code style="background:#f1f5f9;padding:0.15rem 0.4rem;border-radius:0.25rem;">error</code>.
      </p>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Ejemplo curl con streaming</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>curl -X POST 'https://api.dify.ai/v1/chat-messages' \
  -H 'Authorization: Bearer TU_CLAVE_API' \
  -H 'Content-Type: application/json' \
  --no-buffer \
  -d '{"{"}
    "inputs": {"{"}{"}"},
    "query": "Escribe un poema corto sobre la IA.",
    "response_mode": "streaming",
    "conversation_id": "",
    "user": "usuario-123"
  {"}"}'</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Ejemplo Python con streaming</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;"><code>import requests
import json

def stream_chat(query, user="usuario-123"):
    with requests.post(
        "https://api.dify.ai/v1/chat-messages",
        headers={"{"}
            "Authorization": "Bearer TU_CLAVE_API",
            "Content-Type": "application/json",
        {"}"},
        json={"{"}
            "inputs": {"{}"},
            "query": query,
            "response_mode": "streaming",
            "conversation_id": "",
            "user": user,
        {"}"},
        stream=True,
    ) as response:
        for line in response.iter_lines():
            if line and line.startswith(b"data: "):
                data = json.loads(line[6:])
                if data.get("event") == "message":
                    print(data["answer"], end="", flush=True)
                elif data.get("event") == "message_end":
                    print()
                    break

stream_chat("Explica la computación cuántica de forma sencilla.")</code></pre>

      <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">JavaScript / Navegador (fetch con ReadableStream)</h3>
      <pre style="background:#0f172a;color:#e2e8f0;padding:1.25rem;border-radius:0.75rem;overflow-x:auto;font-size:0.82rem;line-height:1.7;margin-bottom:1rem;"><code>async function streamChat(query) {"{"}
  const response = await fetch("https://api.dify.ai/v1/chat-messages", {"{"}
    method: "POST",
    headers: {"{"}
      "Authorization": "Bearer TU_CLAVE_API",
      "Content-Type": "application/json",
    {"}"},
    body: JSON.stringify({"{"}
      inputs: {"{"}{"}"},
      query,
      response_mode: "streaming",
      conversation_id: "",
      user: "usuario-navegador",
    {"}"}),
  {"}"});

  const reader = response.body.getReader();
  const decoder = new TextDecoder();

  while (true) {"{"}
    const {"{"} done, value {"}"} = await reader.read();
    if (done) break;
    const lines = decoder.decode(value).split("\n");
    for (const line of lines) {"{"}
      if (line.startsWith("data: ")) {"{"}
        const data = JSON.parse(line.slice(6));
        if (data.event === "message") {"{"}
          document.getElementById("salida").textContent += data.answer;
        {"}"}
      {"}"}
    {"}"}
  {"}"}
{"}"}

streamChat("¿Cuáles son las ventajas de la IA auto-hospedada?");</code></pre>
    </div>
  </section>

  <!-- Section 6: API auto-hospedada -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">API Dify con instalación auto-hospedada</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        Si auto-hospedas Dify en tu propio servidor, la API funciona exactamente igual — simplemente reemplaza la URL base. Esta es la principal ventaja del auto-hospedaje: controlas la infraestructura, los datos permanecen en tu servidor y no hay límites de créditos de mensajes.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;margin-bottom:1.5rem;">
        <div style="background:#f8fafc;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:0.95rem;font-weight:700;color:#111827;margin-bottom:0.75rem;">Dify Cloud</h3>
          <pre style="background:#0f172a;color:#e2e8f0;padding:0.875rem;border-radius:0.5rem;font-size:0.8rem;margin:0;overflow-x:auto;"><code>BASE_URL = "https://api.dify.ai/v1"</code></pre>
        </div>
