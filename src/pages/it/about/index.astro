---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/about/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Chi Siamo — Dify Hosting: Missione e Metodologia',
  description: 'Scopri la missione editoriale di Dify Hosting, come testiamo i provider, la nostra informativa sulle affiliazioni e come contattarci.',
  url: 'https://dify-hosting.com/it/about/',
  publisher: {
    '@type': 'Organization',
    name: 'Dify Hosting',
    url: 'https://dify-hosting.com',
  },
};

const methodology = [
  { step: '1', label: 'Creare un account reale presso ciascun provider' },
  { step: '2', label: 'Distribuire Dify tramite Docker Compose' },
  { step: '3', label: 'Eseguire test standardizzati per 30 giorni (tempo di risposta, uptime, utilizzo delle risorse)' },
  { step: '4', label: 'Valutare la qualità del supporto' },
  { step: '5', label: 'Calcolare il costo totale di possesso' },
];

const testMetrics = [
  'Tempo di configurazione (minuti dal primo accesso a Dify funzionante)',
  'Tempo alla prima risposta all\'interno di Dify',
  'Utilizzo di CPU e RAM sotto carico simulato',
  'Velocità I/O dello storage',
  'Latenza di rete dalle regioni principali',
  'Accuratezza della fatturazione',
];
---

<BaseLayout
  title="Chi Siamo — Dify Hosting: Missione e Metodologia"
  description="Scopri la missione editoriale di Dify Hosting, come testiamo i provider, la nostra informativa sulle affiliazioni e come contattarci."
  lang="it"
  canonical="https://dify-hosting.com/it/about/"
  hreflang={hreflang}
  schema={schema}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Home', href: '/it/' },
        { label: 'Chi Siamo' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Chi Siamo — Dify Hosting
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:640px;line-height:1.7;">
        La nostra missione, la metodologia di valutazione e gli standard editoriali — per sapere esattamente come arriviamo alle nostre raccomandazioni.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;gap:2.5rem;">

        <!-- Chi Siamo -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Chi Siamo</h2>
          <div class="prose">
            <p>
              Dify Hosting è un sito di confronto indipendente per i provider di self-hosting di Dify. Testiamo ciascun provider distribuendo effettivamente Dify sulla loro infrastruttura e misurando le prestazioni, il tempo di configurazione e il rapporto qualità-prezzo.
            </p>
            <p>
              Siamo un piccolo team di sviluppatori e ingegneri cloud che eseguono Dify in produzione dal 2023. Abbiamo creato questo sito perché non riuscivamo a trovare un confronto onesto e pratico delle opzioni di hosting disponibili — quindi ne abbiamo fatto uno noi stessi.
            </p>
          </div>
        </div>

        <!-- Metodologia -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">La Nostra Metodologia di Valutazione</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Ogni classifica dei provider su questo sito è il risultato di un processo di test standardizzato:
          </p>
          <ol style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.875rem;">
            {methodology.map((item) => (
              <li style="display:flex;align-items:flex-start;gap:1rem;">
                <span style="flex-shrink:0;width:2rem;height:2rem;border-radius:50%;background:#1677FF;color:#fff;font-weight:700;font-size:0.875rem;display:flex;align-items:center;justify-content:center;">
                  {item.step}
                </span>
                <span style="color:#374151;line-height:1.6;padding-top:0.25rem;">{item.label}</span>
              </li>
            ))}
          </ol>
        </div>

        <!-- Cosa Testiamo -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Cosa Misuriamo</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.25rem;">
            La nostra suite di benchmark copre i parametri più importanti per un deployment Dify:
          </p>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            {testMetrics.map((metric) => (
              <li style="display:flex;align-items:flex-start;gap:0.75rem;color:#374151;line-height:1.6;">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-top:0.2rem;">
                  <circle cx="9" cy="9" r="9" fill="#dcfce7"/>
                  <path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="#16a34a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {metric}
              </li>
            ))}
          </ul>
        </div>

        <!-- Informativa sulle Affiliazioni -->
        <div class="card" style="padding:2rem;border-left:4px solid #f59e0b;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Informativa sulle Affiliazioni</h2>
          <div class="prose">
            <p>
              Questo sito guadagna commissioni dai link di affiliazione quando clicchi e ti iscrivi a un provider di hosting. È così che finanziamo i test e la manutenzione continua del sito.
            </p>
            <p>
              Raccomandiamo solo i provider che abbiamo personalmente testato e che useremmo noi stessi. Le nostre classifiche si basano sul merito — prestazioni, valore e affidabilità — non sui tassi di commissione. I provider non vengono mai pagati per comparire nelle nostre classifiche o ricevere un posizionamento più alto.
            </p>
          </div>
        </div>

        <!-- Contatti -->
        <div class="card" style="padding:2rem;" id="contact">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Contattaci</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Usa il modulo qui sotto o scrivici a <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;text-decoration:none;">contact@dify-hosting.com</a>. Di solito rispondiamo entro 24 ore.
          </p>
          <form style="display:flex;flex-direction:column;gap:1rem;" onsubmit="return false;">
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-name" style="font-size:0.875rem;font-weight:600;color:#374151;">Nome</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Il tuo nome"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-email" style="font-size:0.875rem;font-weight:600;color:#374151;">Email</label>
              <input
                id="contact-email"
                type="email"
                placeholder="tu@esempio.com"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-message" style="font-size:0.875rem;font-weight:600;color:#374151;">Messaggio</label>
              <textarea
                id="contact-message"
                rows="5"
                placeholder="Il tuo messaggio..."
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              ></textarea>
            </div>
            <div>
              <button type="submit" class="btn-primary">Invia Messaggio</button>
            </div>
          </form>
        </div>

        <!-- Link Correlati -->
        <div style="padding:1.5rem;background:#f8fafc;border-radius:1rem;border:1px solid #e2e8f0;">
          <p style="font-weight:600;color:#374151;margin-bottom:0.875rem;">Esplora le nostre ricerche:</p>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/it/best-dify-hosting/" class="btn-primary" style="text-decoration:none;">Migliori Provider Dify</a>
            <a href="/it/faq/" class="btn-secondary" style="text-decoration:none;">FAQ su Dify</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
