---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../../i18n/hreflang';

const hreflang = getHreflang('/guides/dify-rag/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Guida Dify RAG 2026: Crea app IA con i tuoi documenti',
  description: 'Guida completa a Dify RAG (Retrieval-Augmented Generation). Scopri come caricare documenti, creare una knowledge base e costruire un chatbot IA che risponde dai tuoi dati.',
  datePublished: '2026-01-01',
  dateModified: '2026-03-24',
  author: { '@type': 'Organization', name: 'Dify Hosting' },
};

const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Cos'è Dify RAG?","acceptedAnswer":{"@type":"Answer","text":"RAG sta per Retrieval-Augmented Generation. Dify RAG permette alla tua IA di cercare nei tuoi documenti, PDF o database prima di rispondere, riducendo drasticamente le allucinazioni e migliorando la precisione su domande specifiche del dominio."}},{"@type":"Question","name":"Quali formati di file supporta Dify RAG?","acceptedAnswer":{"@type":"Answer","text":"La knowledge base di Dify supporta PDF, Word (.docx), testo normale (.txt), Markdown (.md), HTML e CSV. Puoi anche collegare fonti esterne tramite API o sincronizzare con Notion."}},{"@type":"Question","name":"Come riduce Dify RAG le allucinazioni?","acceptedAnswer":{"@type":"Answer","text":"Invece di affidarsi esclusivamente ai dati di addestramento dell'LLM, Dify RAG recupera frammenti rilevanti dai tuoi documenti e li inietta come contesto. Il modello risponde quindi basandosi sui tuoi dati reali."}},{"@type":"Question","name":"Quali database vettoriali funzionano con Dify RAG?","acceptedAnswer":{"@type":"Answer","text":"Dify supporta diversi archivi vettoriali: integrato (predefinito, nessuna configurazione), pgvector (PostgreSQL), Qdrant, Weaviate, Milvus e Pinecone. L'archivio integrato va bene per la maggior parte degli utenti."}}]};
---

<BaseLayout
  title="Guida Dify RAG 2026: Crea app IA con i tuoi documenti"
  description="Guida completa a Dify RAG (Retrieval-Augmented Generation). Scopri come caricare documenti, creare una knowledge base e costruire un chatbot IA che risponde dai tuoi dati."
  lang="it"
  canonical="https://dify-hosting.com/it/guides/dify-rag/"
  hreflang={hreflang}
  schema={[schema, faqSchema]}
>
  <!-- Hero -->
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Home', href: '/it/' },
        { label: 'Guide', href: '/it/guides/' },
        { label: 'Guida Dify RAG' },
      ]} />
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#dcfce7;color:#166534;">Aggiornato marzo 2026</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#fef9c3;color:#713f12;">Guida RAG</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#ede9fe;color:#4c1d95;">Avanzato</span>
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:#fff;line-height:1.2;margin-bottom:1rem;">
        Guida Dify RAG 2026: Rispondi a domande dai tuoi documenti
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:680px;line-height:1.7;">
        La Retrieval-Augmented Generation (RAG) è la funzionalità più potente di Dify. Questa guida ti mostra esattamente come costruire una IA che cerca nei tuoi documenti prima di rispondere — fornendo risposte precise e fondate invece di allucinazioni.
      </p>
    </div>
  </section>

  <!-- Cos'è Dify RAG -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Cos'è Dify RAG?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        RAG sta per <strong>Retrieval-Augmented Generation</strong>. Questa tecnica dà alla tua IA accesso ai tuoi documenti, database e fonti di conoscenza — invece di rispondere solo dai dati di addestramento generici, cerca prima nel tuo contenuto e genera una risposta basata su ciò che ha trovato.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        Gli LLM standard come GPT-4 o Claude allucinano quando vengono interrogati sui tuoi documenti interni, specifiche di prodotto o policy aziendali — perché semplicemente non hanno quei dati. Dify RAG risolve questo problema creando una <strong>knowledge base</strong> dai tuoi file e iniettando i passaggi più rilevanti come contesto prima che il modello risponda.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Il risultato: un chatbot IA che risponde accuratamente dai tuoi dati reali, cita le fonti e dice "non lo so" invece di inventare risposte quando l'informazione non è disponibile.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.75rem;">
        {[
          'Risponde dai tuoi documenti',
          'Riduce drasticamente le allucinazioni',
          'Cita passaggi specifici come fonte',
          'Compatibile con PDF, Word, TXT, Markdown',
          'Nessun fine-tuning del modello necessario',
          'Knowledge base aggiornabile in qualsiasi momento',
        ].map(f => (
          <div style="display:flex;align-items:center;gap:0.5rem;background:#f0fdf4;padding:0.75rem;border-radius:0.5rem;">
            <span style="color:#16a34a;font-weight:700;">✓</span>
            <span style="font-size:0.875rem;color:#166534;">{f}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Come funziona RAG -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Come funziona Dify RAG internamente</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Capire la pipeline ti aiuta a configurarla meglio. Ecco cosa succede quando carichi un documento e poni una domanda al tuo chatbot:
      </p>
      <div style="display:grid;gap:0.75rem;max-width:640px;margin-bottom:1.5rem;">
        {[
          { step: '1', title: 'Ingestione del documento', desc: 'Carichi un file. Dify estrae il contenuto testuale da PDF, documenti Word, Markdown, ecc.' },
          { step: '2', title: 'Frammentazione (chunking)', desc: 'Il testo viene diviso in frammenti più piccoli (tipicamente 500–1000 token) per rendere la ricerca precisa.' },
          { step: '3', title: 'Embedding', desc: 'Ogni frammento viene convertito in un vettore (lista di numeri) tramite un modello di embedding come text-embedding-3-small.' },
          { step: '4', title: 'Archiviazione vettoriale', desc: 'I vettori vengono archiviati in un database vettoriale (integrato, pgvector, Qdrant, Weaviate, Milvus o Pinecone).' },
          { step: '5', title: 'Retrieval della query', desc: 'Quando un utente pone una domanda, viene anch\'essa vettorizzata e i frammenti più simili vengono recuperati dall\'archivio vettoriale.' },
          { step: '6', title: 'Iniezione del contesto', desc: 'I frammenti recuperati vengono iniettati nel prompt dell\'LLM come contesto. Il modello risponde basandosi su questi dati reali.' },
        ].map(s => (
          <div style="display:flex;align-items:flex-start;gap:0.75rem;">
            <span style="width:1.75rem;height:1.75rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;margin-top:0.1rem;">{s.step}</span>
            <div>
              <p style="font-weight:700;font-size:0.9rem;color:#111827;margin:0 0 0.2rem;">{s.title}</p>
              <p style="font-size:0.85rem;color:#4B5563;margin:0;line-height:1.5;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="background:#f0f9ff;border-left:3px solid #1677FF;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#1e40af;">
        <strong>Concetto chiave:</strong> RAG non modifica l'LLM. Aggiunge una fase di recupero prima della generazione. Ciò significa che puoi aggiornare la tua knowledge base in qualsiasi momento senza toccare il modello.
      </div>
    </div>
  </section>

  <!-- Configurare la knowledge base -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">1</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Configurare la tua knowledge base</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        La knowledge base è il luogo dove carichi e indicizzi i tuoi documenti. Segui questi passaggi:
      </p>
      <div style="display:grid;gap:1rem;max-width:640px;margin-bottom:1.5rem;">
        {[
          { step: '1', title: 'Aprire Dify → scheda Knowledge', desc: 'Fai clic su "Knowledge" (Conoscenza) nella barra di navigazione superiore. Qui si trovano tutte le tue raccolte di documenti.' },
          { step: '2', title: 'Creare una nuova knowledge base', desc: 'Fai clic su "+ Crea knowledge base". Dagli un nome descrittivo (es.: "Documentazione prodotto", "FAQ Supporto").' },
          { step: '3', title: 'Caricare i file', desc: 'Trascina e rilascia o sfoglia per caricare. Supportati: PDF, Word (.docx), TXT, Markdown (.md), HTML, CSV. Si possono caricare più file contemporaneamente.' },
          { step: '4', title: 'Scegliere la strategia di frammentazione', desc: 'Seleziona "Automatico" per la maggior parte dei casi. Questo divide i documenti per paragrafi e intestazioni. Per documenti tecnici densi: "Personalizzato" con 800 token e 150 token di sovrapposizione.' },
          { step: '5', title: 'Selezionare il modello di embedding', desc: 'Scegli il tuo modello di embedding. OpenAI text-embedding-3-small è consigliato — veloce, economico e preciso. In self-hosting, nomic-embed-text via Ollama funziona offline.' },
          { step: '6', title: 'Indicizzare i documenti', desc: 'Fai clic su "Salva e processa". Dify frammenta e vettorizza tutto. In base alla dimensione dei documenti, ci vogliono 1–5 minuti. Una barra di avanzamento mostra lo stato.' },
        ].map(s => (
          <div class="card" style="display:flex;gap:1rem;align-items:flex-start;padding:1rem;">
            <span style="width:1.75rem;height:1.75rem;background:#eff6ff;color:#1677FF;border:2px solid #1677FF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;flex-shrink:0;">{s.step}</span>
            <div>
              <p style="font-weight:700;font-size:0.9rem;color:#111827;margin:0 0 0.25rem;">{s.title}</p>
              <p style="font-size:0.85rem;color:#4B5563;margin:0;line-height:1.5;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="background:#fef9c3;border-left:3px solid #f59e0b;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#713f12;">
        <strong>Suggerimento:</strong> I documenti ben formattati si indicizzano meglio. Rimuovi intestazioni, piè di pagina, numeri di pagina e testi boilerplate dai tuoi PDF prima di caricarli per ottenere la migliore qualità di recupero.
      </div>
    </div>
  </section>

  <!-- Collegare RAG alla tua app -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">2</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Collegare RAG alla tua applicazione</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Una volta indicizzata la tua knowledge base, collegala a un chatbot o agente:
      </p>
      <div style="display:grid;gap:0.75rem;max-width:640px;margin-bottom:1.5rem;">
        {[
          { step: '1', action: 'Apri la tua applicazione Chatbot o Agente in Studio' },
          { step: '2', action: 'Nel pannello sinistro, trova la sezione "Contesto"' },
          { step: '3', action: 'Fai clic su "+ Aggiungi contesto" e seleziona la tua knowledge base' },
          { step: '4', action: 'Imposta la modalità di recupero su "Ricerca semantica" (consigliata) o "Ricerca a testo integrale" per la corrispondenza per parole chiave' },
          { step: '5', action: 'Imposta "Top K" a 3–5 (quanti frammenti recuperare per query). Inizia con 3.' },
          { step: '6', action: 'Attiva la "Soglia di punteggio" a 0,5 per filtrare i risultati poco rilevanti' },
          { step: '7', action: 'Testa nel pannello di anteprima con domande dai tuoi documenti. Verifica che il bot citi informazioni corrette.' },
        ].map(s => (
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <span style="width:1.5rem;height:1.5rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;">{s.step}</span>
            <p style="font-size:0.875rem;color:#374151;margin:0;">{s.action}</p>
          </div>
        ))}
      </div>
      <div style="background:#f0fdf4;border-left:3px solid #16a34a;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#166534;">
        <strong>Consiglio pro:</strong> Aggiungi un'istruzione di citazione nel tuo prompt di sistema: "Quando rispondi dal contesto fornito, cita sempre il nome del documento sorgente." Questo chiarisce da quale documento proviene la risposta.
      </div>
    </div>
  </section>

  <!-- Database vettoriali supportati -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">3</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Database vettoriali supportati</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify supporta più archivi vettoriali. Per la maggior parte degli utenti, l'archivio integrato è sufficiente. Per deployment su larga scala (milioni di documenti), passa a un database dedicato:
      </p>
      <div style="overflow-x:auto;margin-bottom:1.5rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
          <thead>
            <tr style="background:#f8fafc;">
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Archivio vettoriale</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Configurazione</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Ideale per</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Costo</th>
            </tr>
          </thead>
          <tbody>
            {[
              { name: 'Integrato (predefinito)', setup: 'Nessuna', best: 'La maggior parte degli utenti — fino a ~100k documenti', cost: 'Gratuito', highlight: true },
              { name: 'pgvector', setup: 'Estensione PostgreSQL', best: 'Utenti PostgreSQL esistenti', cost: 'Gratuito (self-hosted)', highlight: false },
              { name: 'Qdrant', setup: 'Container Docker', best: 'Self-hosted, alte prestazioni', cost: 'Gratuito (self-hosted)', highlight: false },
              { name: 'Weaviate', setup: 'Docker o cloud', best: 'Dati multimodali (testo + immagini)', cost: 'Gratuito / cloud a pagamento', highlight: false },
              { name: 'Milvus', setup: 'Docker o Zilliz cloud', best: 'Miliardi di vettori, scala enterprise', cost: 'Gratuito / cloud a pagamento', highlight: false },
              { name: 'Pinecone', setup: 'Solo chiave API', best: 'Fully managed, nessuna infrastruttura da gestire', cost: 'SaaS a pagamento', highlight: false },
            ].map(r => (
              <tr style={`border-bottom:1px solid #f3f4f6;${r.highlight ? 'background:#f0fdf4;' : ''}`}>
                <td style="padding:0.75rem 1rem;font-weight:600;color:#111827;">{r.name} {r.highlight && <span style="font-size:0.7rem;background:#16a34a;color:#fff;padding:0.1rem 0.4rem;border-radius:9999px;margin-left:0.4rem;">Consigliato</span>}</td>
                <td style="padding:0.75rem 1rem;color:#4B5563;">{r.setup}</td>
                <td style="padding:0.75rem 1rem;color:#4B5563;">{r.best}</td>
                <td style="padding:0.75rem 1rem;color:#4B5563;">{r.cost}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div style="background:#fef9c3;border-left:3px solid #f59e0b;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#713f12;">
        <strong>Raccomandazione:</strong> Inizia con l'archivio vettoriale integrato. Non richiede alcuna configurazione e funziona bene per la maggior parte dei progetti. Passa a uno esterno solo se hai più di 100.000 frammenti di documenti.
      </div>
    </div>
  </section>

  <!-- Suggerimenti RAG -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">4</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Suggerimenti RAG per i migliori risultati</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Questi consigli di configurazione miglioreranno significativamente la precisione del tuo RAG:
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;">
        {[
          {
            title: 'Dimensione ottimale del frammento: 500–1000 token',
            desc: 'Troppo piccolo = contesto mancante. Troppo grande = rilevanza diluita. Per la maggior parte dei documenti, 600 token con 100 token di sovrapposizione è l\'ideale.',
          },
          {
            title: 'Pulire i documenti sorgente',
            desc: 'Rimuovi intestazioni e piè di pagina ripetuti, numeri di pagina e menu di navigazione. Questi elementi aggiungono rumore che danneggia la qualità del recupero.',
          },
          {
            title: 'Usare il filtraggio per metadati',
            desc: 'Etichetta i documenti con categorie (es.: "prodotto: fatturazione", "tipo: FAQ"). I filtri permettono di recuperare solo i sottoinsiemi rilevanti per ogni query.',
          },
          {
            title: 'Separare le knowledge base per argomento',
            desc: 'Non mescolare il manuale del prodotto con la policy HR. Dataset separati danno un recupero più preciso. Puoi collegare più basi alla stessa app.',
          },
          {
            title: 'Usare la ricerca ibrida',
            desc: 'Dify supporta la modalità ibrida (semantica + parole chiave combinata). Attivala per una migliore copertura dei termini esatti: codici prodotto, nomi propri.',
          },
          {
            title: 'Monitorare il recupero nei log',
            desc: 'Vai a Log e Annotazioni nella tua app per vedere esattamente quali frammenti sono stati recuperati per ogni query. Usalo per diagnosticare risposte scorrette.',
          },
        ].map(t => (
          <div class="card">
            <h3 style="font-size:0.95rem;font-weight:700;color:#111827;margin-bottom:0.4rem;">{t.title}</h3>
            <p style="font-size:0.85rem;color:#6B7280;line-height:1.5;margin:0;">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modalità di recupero -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Le modalità di recupero spiegate</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify offre tre modalità di recupero. Scegli in base al tipo di contenuto:
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;">
        <div style="background:#eff6ff;border:2px solid #1677FF;border-radius:0.75rem;padding:1.25rem;">
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <span style="background:#1677FF;color:#fff;padding:0.15rem 0.5rem;border-radius:9999px;font-size:0.75rem;font-weight:700;">Consigliato</span>
          </div>
          <h3 style="font-size:1rem;font-weight:700;color:#1e40af;margin-bottom:0.5rem;">Ricerca semantica</h3>
          <p style="font-size:0.85rem;color:#1e40af;line-height:1.5;margin:0;">Trova contenuti concettualmente simili anche se le parole esatte differiscono. Ideale per domande in linguaggio naturale su argomenti complessi. Usa la similarità vettoriale.</p>
        </div>
        <div style="background:#f8fafc;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Ricerca a testo integrale</h3>
