---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../../i18n/hreflang';

const hreflang = getHreflang('/guides/dify-rag/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Guide Dify RAG 2026 : Créez des apps IA avec vos propres documents',
  description: 'Guide complet sur Dify RAG (Retrieval-Augmented Generation). Apprenez à uploader des documents, créer une base de connaissances et construire un chatbot IA qui répond depuis vos données.',
  datePublished: '2026-01-01',
  dateModified: '2026-03-24',
  author: { '@type': 'Organization', name: 'Dify Hosting' },
};

const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Qu'est-ce que Dify RAG ?","acceptedAnswer":{"@type":"Answer","text":"RAG signifie Retrieval-Augmented Generation. Dify RAG permet à votre IA de rechercher dans vos propres documents, PDF ou bases de données avant de répondre — réduisant considérablement les hallucinations et améliorant la précision."}},{"@type":"Question","name":"Quels formats de fichiers Dify RAG supporte-t-il ?","acceptedAnswer":{"@type":"Answer","text":"La base de connaissances Dify supporte PDF, Word (.docx), texte brut (.txt), Markdown (.md), HTML et CSV. Vous pouvez aussi connecter des sources externes via API ou synchroniser avec Notion."}},{"@type":"Question","name":"Comment Dify RAG réduit-il les hallucinations ?","acceptedAnswer":{"@type":"Answer","text":"Au lieu de s'appuyer uniquement sur les données d'entraînement du LLM, Dify RAG récupère des passages pertinents de vos documents et les injecte comme contexte. Le modèle répond alors à partir de vos données réelles."}},{"@type":"Question","name":"Quelles bases de données vectorielles fonctionnent avec Dify RAG ?","acceptedAnswer":{"@type":"Answer","text":"Dify supporte plusieurs stores vectoriels : intégré (par défaut), pgvector (PostgreSQL), Qdrant, Weaviate, Milvus et Pinecone. Le store intégré convient à la plupart des utilisateurs."}}]};
---

<BaseLayout
  title="Guide Dify RAG 2026 : Créez des apps IA avec vos propres documents"
  description="Guide complet sur Dify RAG (Retrieval-Augmented Generation). Apprenez à uploader des documents, créer une base de connaissances et construire un chatbot IA qui répond depuis vos données."
  lang="fr"
  canonical="https://dify-hosting.com/fr/guides/dify-rag/"
  hreflang={hreflang}
  schema={[schema, faqSchema]}
>
  <!-- Hero -->
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Accueil', href: '/fr/' },
        { label: 'Guides', href: '/fr/guides/' },
        { label: 'Guide Dify RAG' },
      ]} />
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#dcfce7;color:#166534;">Mis à jour mars 2026</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#fef9c3;color:#713f12;">Guide RAG</span>
        <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#ede9fe;color:#4c1d95;">Avancé</span>
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:#fff;line-height:1.2;margin-bottom:1rem;">
        Guide Dify RAG 2026 : Répondre aux questions depuis vos propres documents
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:680px;line-height:1.7;">
        La Retrieval-Augmented Generation (RAG) est la fonctionnalité la plus puissante de Dify. Ce guide vous montre exactement comment créer une IA qui recherche dans vos documents avant de répondre — offrant des réponses précises et fondées plutôt que des hallucinations.
      </p>
    </div>
  </section>

  <!-- Qu'est-ce que Dify RAG -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Qu'est-ce que Dify RAG ?</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        RAG signifie <strong>Retrieval-Augmented Generation</strong>. Cette technique donne à votre IA accès à vos propres documents, bases de données et sources de connaissances — au lieu de répondre uniquement à partir de données d'entraînement génériques, elle recherche d'abord dans votre contenu et génère une réponse basée sur ce qu'elle a trouvé.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1rem;">
        Les LLMs standard comme GPT-4 ou Claude hallucinent lorsqu'on leur pose des questions sur vos documents internes, vos spécifications produit ou vos politiques d'entreprise — parce qu'ils ne disposent tout simplement pas de ces données. Dify RAG résout ce problème en créant une <strong>base de connaissances</strong> à partir de vos fichiers et en injectant les passages les plus pertinents comme contexte avant que le modèle réponde.
      </p>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Le résultat : un chatbot IA qui répond avec précision depuis vos données réelles, cite ses sources, et dit « je ne sais pas » plutôt qu'inventer des réponses lorsque l'information n'est pas disponible.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.75rem;">
        {[
          'Répond depuis vos documents',
          'Réduit drastiquement les hallucinations',
          'Cite des passages spécifiques',
          'Compatible PDF, Word, TXT, Markdown',
          'Aucun fine-tuning du modèle nécessaire',
          'Base de connaissances mise à jour à tout moment',
        ].map(f => (
          <div style="display:flex;align-items:center;gap:0.5rem;background:#f0fdf4;padding:0.75rem;border-radius:0.5rem;">
            <span style="color:#16a34a;font-weight:700;">✓</span>
            <span style="font-size:0.875rem;color:#166534;">{f}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fonctionnement de RAG -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Comment fonctionne Dify RAG en coulisses</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Comprendre le pipeline vous aide à mieux le configurer. Voici ce qui se passe lorsque vous uploadez un document et posez une question à votre chatbot :
      </p>
      <div style="display:grid;gap:0.75rem;max-width:640px;margin-bottom:1.5rem;">
        {[
          { step: '1', title: 'Ingestion du document', desc: 'Vous uploadez un fichier. Dify extrait le contenu textuel des PDFs, documents Word, Markdown, etc.' },
          { step: '2', title: 'Découpage (chunking)', desc: 'Le texte est divisé en morceaux plus petits (typiquement 500–1000 tokens) pour que la recherche soit précise.' },
          { step: '3', title: 'Embedding', desc: 'Chaque morceau est converti en vecteur (liste de nombres) via un modèle d\'embedding comme text-embedding-3-small.' },
          { step: '4', title: 'Stockage vectoriel', desc: 'Les vecteurs sont stockés dans une base de données vectorielle (intégrée, pgvector, Qdrant, Weaviate, Milvus ou Pinecone).' },
          { step: '5', title: 'Retrieval de la requête', desc: 'Lorsqu\'un utilisateur pose une question, elle est aussi vectorisée et les morceaux les plus similaires sont récupérés.' },
          { step: '6', title: 'Injection de contexte', desc: 'Les morceaux récupérés sont injectés dans le prompt LLM comme contexte. Le modèle répond en se basant sur ces données réelles.' },
        ].map(s => (
          <div style="display:flex;align-items:flex-start;gap:0.75rem;">
            <span style="width:1.75rem;height:1.75rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;margin-top:0.1rem;">{s.step}</span>
            <div>
              <p style="font-weight:700;font-size:0.9rem;color:#111827;margin:0 0 0.2rem;">{s.title}</p>
              <p style="font-size:0.85rem;color:#4B5563;margin:0;line-height:1.5;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="background:#f0f9ff;border-left:3px solid #1677FF;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#1e40af;">
        <strong>Point clé :</strong> RAG ne modifie pas le LLM. Il ajoute une étape de recherche avant la génération. Cela signifie que vous pouvez mettre à jour votre base de connaissances à tout moment sans toucher au modèle.
      </div>
    </div>
  </section>

  <!-- Configurer la base de connaissances -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">1</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Configurer votre base de connaissances</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        La base de connaissances est l'endroit où vous uploadez et indexez vos documents. Suivez ces étapes :
      </p>
      <div style="display:grid;gap:1rem;max-width:640px;margin-bottom:1.5rem;">
        {[
          { step: '1', title: 'Ouvrir Dify → onglet Knowledge', desc: 'Cliquez sur "Knowledge" (Connaissances) dans la navigation supérieure. C\'est ici que vivent toutes vos collections de documents.' },
          { step: '2', title: 'Créer une nouvelle base de connaissances', desc: 'Cliquez sur "+ Créer une base de connaissances". Donnez-lui un nom descriptif (ex. : "Documentation produit", "FAQ Support").' },
          { step: '3', title: 'Uploader vos fichiers', desc: 'Glissez-déposez ou parcourez pour uploader. Supportés : PDF, Word (.docx), TXT, Markdown (.md), HTML, CSV. Plusieurs fichiers simultanément.' },
          { step: '4', title: 'Choisir la stratégie de découpage', desc: 'Sélectionnez "Automatique" pour la plupart des cas. Cela divise les documents par paragraphes et titres. Pour des docs techniques denses : "Personnalisé" avec 800 tokens et 150 tokens de chevauchement.' },
          { step: '5', title: 'Sélectionner le modèle d\'embedding', desc: 'Choisissez votre modèle d\'embedding. OpenAI text-embedding-3-small est recommandé — rapide, peu coûteux et précis. En self-hosting, nomic-embed-text via Ollama fonctionne hors ligne.' },
          { step: '6', title: 'Indexer vos documents', desc: 'Cliquez sur "Enregistrer et traiter". Dify découpe et vectorise tout. Selon la taille des documents, cela prend 1–5 minutes. Une barre de progression indique l\'avancement.' },
        ].map(s => (
          <div class="card" style="display:flex;gap:1rem;align-items:flex-start;padding:1rem;">
            <span style="width:1.75rem;height:1.75rem;background:#eff6ff;color:#1677FF;border:2px solid #1677FF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;flex-shrink:0;">{s.step}</span>
            <div>
              <p style="font-weight:700;font-size:0.9rem;color:#111827;margin:0 0 0.25rem;">{s.title}</p>
              <p style="font-size:0.85rem;color:#4B5563;margin:0;line-height:1.5;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="background:#fef9c3;border-left:3px solid #f59e0b;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#713f12;">
        <strong>Conseil :</strong> Les documents bien formatés s'indexent mieux. Supprimez les en-têtes, pieds de page, numéros de page et textes boilerplate de vos PDFs avant de les uploader pour une meilleure qualité de récupération.
      </div>
    </div>
  </section>

  <!-- Connecter RAG à votre app -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">2</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Connecter RAG à votre application</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Une fois votre base de connaissances indexée, attachez-la à un chatbot ou un agent :
      </p>
      <div style="display:grid;gap:0.75rem;max-width:640px;margin-bottom:1.5rem;">
        {[
          { step: '1', action: 'Ouvrez votre application Chatbot ou Agent dans Studio' },
          { step: '2', action: 'Dans le panneau gauche, trouvez la section "Contexte"' },
          { step: '3', action: 'Cliquez sur "+ Ajouter un contexte" et sélectionnez votre base de connaissances' },
          { step: '4', action: 'Réglez le mode de récupération sur "Recherche sémantique" (recommandé) ou "Recherche plein texte" pour la correspondance par mots-clés' },
          { step: '5', action: 'Définissez "Top K" à 3–5 (combien de morceaux récupérer par requête). Commencez par 3.' },
          { step: '6', action: 'Activez le "Seuil de score" à 0,5 pour filtrer les résultats peu pertinents' },
          { step: '7', action: 'Testez dans le panneau de prévisualisation avec des questions de vos documents. Vérifiez que le bot cite les bonnes infos.' },
        ].map(s => (
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <span style="width:1.5rem;height:1.5rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;">{s.step}</span>
            <p style="font-size:0.875rem;color:#374151;margin:0;">{s.action}</p>
          </div>
        ))}
      </div>
      <div style="background:#f0fdf4;border-left:3px solid #16a34a;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#166534;">
        <strong>Conseil pro :</strong> Ajoutez une instruction de citation dans votre prompt système : "Lorsque vous répondez à partir du contexte fourni, citez toujours le nom du document source." Cela clarifie d'où provient la réponse.
      </div>
    </div>
  </section>

  <!-- Bases de données vectorielles -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">3</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Bases de données vectorielles supportées</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify supporte plusieurs stores vectoriels. Pour la plupart des utilisateurs, le store intégré suffit. Pour les déploiements à grande échelle (millions de documents), passez à une base dédiée :
      </p>
      <div style="overflow-x:auto;margin-bottom:1.5rem;">
        <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
          <thead>
            <tr style="background:#f8fafc;">
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Store vectoriel</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Installation</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Idéal pour</th>
              <th style="text-align:left;padding:0.75rem 1rem;font-weight:700;color:#111827;border-bottom:2px solid #e5e7eb;">Coût</th>
            </tr>
          </thead>
          <tbody>
            {[
              { name: 'Intégré (par défaut)', setup: 'Aucune', best: 'La plupart des utilisateurs — jusqu\'à ~100k documents', cost: 'Gratuit', highlight: true },
              { name: 'pgvector', setup: 'Extension PostgreSQL', best: 'Utilisateurs PostgreSQL existants', cost: 'Gratuit (self-hosted)', highlight: false },
              { name: 'Qdrant', setup: 'Conteneur Docker', best: 'Self-hosted, haute performance', cost: 'Gratuit (self-hosted)', highlight: false },
              { name: 'Weaviate', setup: 'Docker ou cloud', best: 'Données multimodales (texte + images)', cost: 'Gratuit / cloud payant', highlight: false },
              { name: 'Milvus', setup: 'Docker ou Zilliz cloud', best: 'Milliards de vecteurs, échelle enterprise', cost: 'Gratuit / cloud payant', highlight: false },
              { name: 'Pinecone', setup: 'Clé API uniquement', best: 'Fully managed, aucune infra à gérer', cost: 'SaaS payant', highlight: false },
            ].map(r => (
              <tr style={`border-bottom:1px solid #f3f4f6;${r.highlight ? 'background:#f0fdf4;' : ''}`}>
                <td style="padding:0.75rem 1rem;font-weight:600;color:#111827;">{r.name} {r.highlight && <span style="font-size:0.7rem;background:#16a34a;color:#fff;padding:0.1rem 0.4rem;border-radius:9999px;margin-left:0.4rem;">Recommandé</span>}</td>
                <td style="padding:0.75rem 1rem;color:#4B5563;">{r.setup}</td>
                <td style="padding:0.75rem 1rem;color:#4B5563;">{r.best}</td>
                <td style="padding:0.75rem 1rem;color:#4B5563;">{r.cost}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div style="background:#fef9c3;border-left:3px solid #f59e0b;padding:0.75rem 1rem;border-radius:0 0.5rem 0.5rem 0;font-size:0.875rem;color:#713f12;">
        <strong>Recommandation :</strong> Commencez avec le store vectoriel intégré. Il ne nécessite aucune configuration et fonctionne bien pour la plupart des projets. Ne passez à un store externe que si vous avez plus de 100 000 chunks de documents.
      </div>
    </div>
  </section>

  <!-- Conseils RAG -->
  <section class="section" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <span style="width:2rem;height:2rem;background:#1677FF;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;">4</span>
        <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin:0;">Conseils RAG pour de meilleurs résultats</h2>
      </div>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Ces conseils de configuration amélioreront significativement la précision de votre RAG :
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;">
        {[
          {
            title: 'Taille de chunk optimale : 500–1000 tokens',
            desc: 'Trop petit = contexte insuffisant. Trop grand = pertinence diluée. Pour la plupart des docs, 600 tokens avec 100 tokens de chevauchement est idéal.',
          },
          {
            title: 'Nettoyer les documents sources',
            desc: 'Supprimez les en-têtes et pieds de page répétés, numéros de page et menus de navigation. Ces éléments ajoutent du bruit qui nuit à la qualité de récupération.',
          },
          {
            title: 'Utiliser le filtrage par métadonnées',
            desc: 'Étiquetez les documents avec des catégories (ex. : "produit: facturation", "type: FAQ"). Les filtres permettent de récupérer uniquement les sous-ensembles pertinents.',
          },
          {
            title: 'Séparer les bases par sujet',
            desc: 'Ne mélangez pas le manuel produit avec la politique RH. Des datasets séparés donnent un retrieval plus précis. Vous pouvez attacher plusieurs bases à une même app.',
          },
          {
            title: 'Utiliser la recherche hybride',
            desc: 'Dify supporte le mode hybride (sémantique + mots-clés combinés). Activez-le pour une meilleure couverture des termes exacts : codes produit, noms propres.',
          },
          {
            title: 'Surveiller le retrieval dans les logs',
            desc: 'Allez dans Logs & Annotations de votre app pour voir exactement quels chunks ont été récupérés pour chaque requête. Utilisez cela pour déboguer les mauvaises réponses.',
          },
        ].map(t => (
          <div class="card">
            <h3 style="font-size:0.95rem;font-weight:700;color:#111827;margin-bottom:0.4rem;">{t.title}</h3>
            <p style="font-size:0.85rem;color:#6B7280;line-height:1.5;margin:0;">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modes de récupération -->
  <section class="section section-alt" style="padding-top:2.5rem;padding-bottom:2.5rem;">
    <div class="container-sm">
      <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Les modes de récupération expliqués</h2>
      <p style="color:#4B5563;line-height:1.7;margin-bottom:1.5rem;">
        Dify propose trois modes de récupération. Choisissez selon votre type de contenu :
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;">
        <div style="background:#eff6ff;border:2px solid #1677FF;border-radius:0.75rem;padding:1.25rem;">
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <span style="background:#1677FF;color:#fff;padding:0.15rem 0.5rem;border-radius:9999px;font-size:0.75rem;font-weight:700;">Recommandé</span>
          </div>
          <h3 style="font-size:1rem;font-weight:700;color:#1e40af;margin-bottom:0.5rem;">Recherche sémantique</h3>
          <p style="font-size:0.85rem;color:#1e40af;line-height:1.5;margin:0;">Trouve du contenu conceptuellement similaire même si les mots exacts diffèrent. Idéal pour les questions en langage naturel sur des sujets complexes. Utilise la similarité vectorielle.</p>
        </div>
        <div style="background:#f8fafc;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.25rem;">
          <h3 style="font-size:1rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Recherche plein texte</h3>
          <p style="font-size:0.85rem;color:#4B5563;line-height:1.5;margin:0;">Recherche par mots-clés comme un moteur de recherche traditionnel. Meilleure pour la correspondance exacte : codes produit, noms, IDs. Rapide et prévisible.</p>
