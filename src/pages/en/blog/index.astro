---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/blog/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Dify Hosting Blog',
  description: 'Latest news and guides about Dify, self-hosted AI, and cloud hosting trends.',
  url: 'https://dify-hosting.com/en/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'Dify Hosting',
    url: 'https://dify-hosting.com',
  },
  blogPost: [
    {
      '@type': 'BlogPosting',
      headline: "What's New in Dify 2026: Major Features Review",
      datePublished: '2026-03-15',
      url: 'https://dify-hosting.com/en/blog/dify-whats-new-2026/',
    },
    {
      '@type': 'BlogPosting',
      headline: 'AI Hosting Trends 2026: What\'s Changing in Cloud Infrastructure',
      datePublished: '2026-02-28',
      url: 'https://dify-hosting.com/en/blog/ai-hosting-trends-2026/',
    },
  ],
};

const posts = [
  {
    title: "What's New in Dify 2026: Major Features Review",
    date: 'March 15, 2026',
    dateISO: '2026-03-15',
    category: 'News',
    excerpt: 'Dify has released several major updates in early 2026, including improved RAG pipeline controls, native MCP server support, and an enhanced workflow engine...',
    href: '/en/blog/dify-whats-new-2026/',
  },
  {
    title: "AI Hosting Trends 2026: What's Changing in Cloud Infrastructure",
    date: 'February 28, 2026',
    dateISO: '2026-02-28',
    category: 'Trends',
    excerpt: "Cloud providers are racing to offer GPU-optimized instances as local LLM adoption grows. Here's what matters for Dify hosting in 2026...",
    href: '/en/blog/ai-hosting-trends-2026/',
  },
];
---

<BaseLayout
  title="Dify Hosting Blog — News, Guides & AI Hosting Trends"
  description="Latest news and guides about Dify, self-hosted AI, and cloud hosting trends. Updated regularly by the Dify Hosting team."
  lang="en"
  canonical="https://dify-hosting.com/en/blog/"
  hreflang={hreflang}
  schema={schema}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Home', href: '/en/' },
        { label: 'Blog' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Dify Hosting Blog
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:640px;line-height:1.7;">
        News, guides, and analysis on Dify, self-hosted AI infrastructure, and cloud hosting trends. Updated regularly by the Dify Hosting team.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;gap:1.5rem;">
        {posts.map((post) => (
          <article class="card" style="padding:0;overflow:hidden;transition:box-shadow 0.2s;">
            <a href={post.href} style="display:block;padding:2rem;text-decoration:none;color:inherit;">
              <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
                <span class="badge-primary" style="font-size:0.75rem;padding:0.2rem 0.7rem;">{post.category}</span>
                <time datetime={post.dateISO} style="font-size:0.85rem;color:#6B7280;">{post.date}</time>
              </div>
              <h2 style="font-size:1.3rem;font-weight:700;color:#111827;line-height:1.4;margin-bottom:0.75rem;transition:color 0.2s;"
                onmouseover="this.style.color='#1677FF'"
                onmouseout="this.style.color='#111827'"
              >
                {post.title}
              </h2>
              <p style="color:#4B5563;line-height:1.75;margin-bottom:1.25rem;">{post.excerpt}</p>
              <span style="font-size:0.875rem;font-weight:600;color:#1677FF;display:inline-flex;align-items:center;gap:0.375rem;">
                Read article
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 7h8M7 3l4 4-4 4"/>
                </svg>
              </span>
            </a>
          </article>
        ))}
      </div>

      <div style="margin-top:3rem;text-align:center;padding:2rem;background:#f8fafc;border-radius:1rem;border:1px solid #e2e8f0;">
        <p style="color:#4B5563;margin-bottom:1rem;">Looking for hosting recommendations?</p>
        <a href="/en/best-dify-hosting/" class="btn-primary" style="text-decoration:none;">Compare Dify Hosting Providers</a>
      </div>
    </div>
  </section>
</BaseLayout>
