---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/contact/');
---

<BaseLayout
  title="Contact Dify Hosting — Get in Touch"
  description="Contact the Dify Hosting team. Questions about our reviews, affiliate programme, or partnership opportunities."
  lang="en"
  canonical="https://dify-hosting.com/en/contact/"
  hreflang={hreflang}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Home', href: '/en/' },
        { label: 'Contact' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Contact Us
      </h1>
      <p style="font-size:1.05rem;color:#94a3b8;max-width:560px;line-height:1.7;">
        Have a question, spotted an error, or want to discuss a partnership? We'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;max-width:900px;">

        <!-- Contact Form -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.3rem;font-weight:700;color:#111827;margin-bottom:0.375rem;">Send a Message</h2>
          <p style="color:#6B7280;font-size:0.875rem;margin-bottom:1.5rem;">We typically respond within 24 hours.</p>
          <form style="display:flex;flex-direction:column;gap:1rem;" onsubmit="return false;">
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="c-name" style="font-size:0.875rem;font-weight:600;color:#374151;">Name</label>
              <input
                id="c-name"
                type="text"
                placeholder="Your name"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="c-email" style="font-size:0.875rem;font-weight:600;color:#374151;">Email</label>
              <input
                id="c-email"
                type="email"
                placeholder="you@example.com"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="c-subject" style="font-size:0.875rem;font-weight:600;color:#374151;">Subject</label>
              <select
                id="c-subject"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              >
                <option value="">Select a topic…</option>
                <option value="review">Question about a review</option>
                <option value="correction">Correction / factual error</option>
                <option value="partnership">Partnership / affiliate</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="c-message" style="font-size:0.875rem;font-weight:600;color:#374151;">Message</label>
              <textarea
                id="c-message"
                rows="5"
                placeholder="Your message…"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              ></textarea>
            </div>
            <div>
              <button type="submit" class="btn-primary">Send Message</button>
            </div>
          </form>
        </div>

        <!-- Contact Info -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="card" style="padding:1.5rem;">
            <h3 style="font-weight:700;color:#111827;margin-bottom:0.5rem;font-size:1rem;">Email</h3>
            <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;text-decoration:none;font-size:0.9375rem;">contact@dify-hosting.com</a>
            <p style="color:#6B7280;font-size:0.8rem;margin-top:0.375rem;">We respond within 24 hours on weekdays.</p>
          </div>
          <div class="card" style="padding:1.5rem;">
            <h3 style="font-weight:700;color:#111827;margin-bottom:0.5rem;font-size:1rem;">Common Topics</h3>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
              {[
                'Factual corrections to reviews',
                'Affiliate & partnership enquiries',
                'Adding a new provider',
                'Press & media requests',
                'General feedback',
              ].map((item) => (
                <li style="display:flex;align-items:center;gap:0.5rem;color:#4B5563;font-size:0.875rem;">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="7" fill="#dbeafe"/><path d="M4 7l2 2 4-4" stroke="#1677FF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="card" style="padding:1.5rem;">
            <h3 style="font-weight:700;color:#111827;margin-bottom:0.5rem;font-size:1rem;">Other Resources</h3>
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              <a href="/en/about/" style="color:#1677FF;text-decoration:none;font-size:0.875rem;">About & Methodology →</a>
              <a href="/en/affiliate-disclosure/" style="color:#1677FF;text-decoration:none;font-size:0.875rem;">Affiliate Disclosure →</a>
              <a href="/en/privacy-policy/" style="color:#1677FF;text-decoration:none;font-size:0.875rem;">Privacy Policy →</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (max-width: 768px) {
    .container-sm > div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
