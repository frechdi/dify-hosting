---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/affiliate-disclosure/');
---

<BaseLayout
  title="Affiliate Disclosure — Dify Hosting"
  description="Dify Hosting earns commissions from affiliate links. Learn how this works and how it affects our rankings."
  lang="en"
  canonical="https://dify-hosting.com/en/affiliate-disclosure/"
  hreflang={hreflang}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Home', href: '/en/' },
        { label: 'Affiliate Disclosure' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        Affiliate Disclosure
      </h1>
      <p style="color:#94a3b8;font-size:0.95rem;">Last updated: March 2026</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="max-width:800px;display:flex;flex-direction:column;gap:1.5rem;">

        <!-- TL;DR banner -->
        <div style="background:#fef3c7;border:1px solid #fbbf24;border-radius:0.875rem;padding:1.25rem 1.5rem;">
          <p style="font-weight:700;color:#92400e;margin-bottom:0.375rem;">The short version</p>
          <p style="color:#78350f;font-size:0.9375rem;line-height:1.65;margin:0;">
            Some links on this site earn us a commission when you sign up with a provider. This never affects our rankings or scores — we only recommend providers we have personally tested and would use ourselves.
          </p>
        </div>

        <div class="card" style="padding:2rem;">
          <div class="prose">
            <h2>How Affiliate Links Work</h2>
            <p>
              When you click a link to a hosting provider on this site and then create an account or make a purchase, we may receive a referral commission from that provider. The commission is paid by the provider — it does not add any cost to you.
            </p>
            <p>
              Affiliate links are clearly indicated where practical and are identified in our footer with the note "This site contains affiliate links."
            </p>

            <h2>How This Affects Our Reviews</h2>
            <p>
              It doesn't — that's the short answer. Our editorial process:
            </p>
            <ul>
              <li><strong>Rankings are set before we check commission rates.</strong> We benchmark each provider independently, then rank by score.</li>
              <li><strong>No provider can pay for placement.</strong> We have never accepted, and will never accept, payment to improve a provider's ranking or review score.</li>
              <li><strong>We cover non-affiliate providers too.</strong> Some providers in our comparisons do not have affiliate programs. We include them anyway if they are relevant to our readers.</li>
              <li><strong>Negative findings are published.</strong> If a provider performs poorly in our tests, we say so — even if they pay higher commissions than alternatives.</li>
            </ul>

            <h2>FTC Compliance</h2>
            <p>
              In accordance with the US Federal Trade Commission's guidelines (<a href="https://www.ftc.gov/business-guidance/resources/disclosures-101-social-media-influencers" style="color:#1677FF;" target="_blank" rel="noopener noreferrer">16 CFR Part 255</a>), we disclose our affiliate relationships clearly. This page, plus the footer note on every page of the site, constitutes our standing disclosure.
            </p>

            <h2>Which Providers Have Affiliate Programs?</h2>
            <p>
              Currently, most major providers we review — including Hetzner, Hostinger, DigitalOcean, Vultr, Elestio, Railway, Render, and Kamatera — have affiliate or referral programmes. Specific commission structures vary and change over time; we do not publish individual rates as they are subject to NDA or change frequently.
            </p>

            <h2>Questions?</h2>
            <p>
              If you have questions about our affiliate relationships or how we fund this site, email us at <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;">contact@dify-hosting.com</a>.
            </p>
          </div>
        </div>

        <div style="padding:1.25rem 1.5rem;background:#f8fafc;border-radius:0.875rem;border:1px solid #e2e8f0;">
          <p style="font-weight:600;color:#374151;margin-bottom:0.75rem;">Related pages:</p>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/en/privacy-policy/" class="btn-secondary" style="text-decoration:none;">Privacy Policy</a>
            <a href="/en/about/" class="btn-secondary" style="text-decoration:none;">About & Methodology</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .prose h2 { font-size:1.3rem;font-weight:700;color:#111827;margin-top:2rem;margin-bottom:0.75rem; }
  .prose p { color:#4B5563;line-height:1.75;margin-bottom:1rem; }
  .prose ul { color:#4B5563;line-height:1.75;padding-left:1.5rem;margin-bottom:1rem; }
  .prose li { margin-bottom:0.5rem; }
  .prose strong { color:#1f2937; }
</style>
