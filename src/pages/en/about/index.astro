---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getHreflang } from '../../../i18n/hreflang';

const hreflang = getHreflang('/about/');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Dify Hosting — Our Mission & Review Methodology',
  description: 'Learn about Dify Hosting\'s editorial mission, how we test providers, our affiliate disclosure and how to contact us.',
  url: 'https://dify-hosting.com/en/about/',
  publisher: {
    '@type': 'Organization',
    name: 'Dify Hosting',
    url: 'https://dify-hosting.com',
  },
};

const methodology = [
  { step: '1', label: 'Create a real account with each provider' },
  { step: '2', label: 'Deploy Dify using Docker Compose' },
  { step: '3', label: 'Run standardized tests over 30 days (response time, uptime, resource usage)' },
  { step: '4', label: 'Evaluate support quality' },
  { step: '5', label: 'Calculate true cost of ownership' },
];

const testMetrics = [
  'Setup time (minutes from first login to working Dify)',
  'Time-to-first-response inside Dify',
  'CPU and RAM usage under simulated load',
  'Storage I/O speed',
  'Network latency from key regions',
  'Billing accuracy',
];
---

<BaseLayout
  title="About Dify Hosting — Our Mission & Review Methodology"
  description="Learn about Dify Hosting's editorial mission, how we test providers, our affiliate disclosure and how to contact us."
  lang="en"
  canonical="https://dify-hosting.com/en/about/"
  hreflang={hreflang}
  schema={schema}
>
  <section class="section" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding-bottom:3rem;">
    <div class="container-sm">
      <Breadcrumb items={[
        { label: 'Home', href: '/en/' },
        { label: 'About' },
      ]} />
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;color:#f8fafc;line-height:1.2;margin-bottom:1rem;">
        About Dify Hosting
      </h1>
      <p style="font-size:1.1rem;color:#94a3b8;max-width:640px;line-height:1.7;">
        Our mission, review methodology, and editorial standards — so you know exactly how we reach our recommendations.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-sm">
      <div style="display:grid;gap:2.5rem;">

        <!-- Who We Are -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Who We Are</h2>
          <div class="prose">
            <p>
              Dify Hosting is an independent comparison site for Dify self-hosting providers. We test each provider by actually deploying Dify on their infrastructure and measuring performance, setup time, and value for money.
            </p>
            <p>
              We are a small team of developers and cloud engineers who have been running Dify in production since 2023. We built this site because we couldn't find an honest, hands-on comparison of the hosting options available — so we made one ourselves.
            </p>
          </div>
        </div>

        <!-- Methodology -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Our Review Methodology</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Every provider ranking on this site is the result of a standardized testing process:
          </p>
          <ol style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.875rem;">
            {methodology.map((item) => (
              <li style="display:flex;align-items:flex-start;gap:1rem;">
                <span style="flex-shrink:0;width:2rem;height:2rem;border-radius:50%;background:#1677FF;color:#fff;font-weight:700;font-size:0.875rem;display:flex;align-items:center;justify-content:center;">
                  {item.step}
                </span>
                <span style="color:#374151;line-height:1.6;padding-top:0.25rem;">{item.label}</span>
              </li>
            ))}
          </ol>
        </div>

        <!-- What We Test -->
        <div class="card" style="padding:2rem;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">What We Measure</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.25rem;">
            Our benchmark suite covers the metrics that matter most for a Dify deployment:
          </p>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            {testMetrics.map((metric) => (
              <li style="display:flex;align-items:flex-start;gap:0.75rem;color:#374151;line-height:1.6;">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-top:0.2rem;">
                  <circle cx="9" cy="9" r="9" fill="#dcfce7"/>
                  <path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="#16a34a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {metric}
              </li>
            ))}
          </ul>
        </div>

        <!-- Affiliate Disclosure -->
        <div class="card" style="padding:2rem;border-left:4px solid #f59e0b;">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:1rem;">Affiliate Disclosure</h2>
          <div class="prose">
            <p>
              This site earns commissions from affiliate links when you click through and sign up with a hosting provider. This is how we fund the ongoing testing and maintenance of this site.
            </p>
            <p>
              We only recommend providers we have personally tested and would use ourselves. Our rankings are based on merit — performance, value, and reliability — not commission rates. Providers are never paid to appear in our rankings or receive a higher placement.
            </p>
          </div>
        </div>

        <!-- Contact -->
        <div class="card" style="padding:2rem;" id="contact">
          <h2 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:0.5rem;">Contact Us</h2>
          <p style="color:#4B5563;line-height:1.75;margin-bottom:1.5rem;">
            Use the form below or email us at <a href="mailto:contact@dify-hosting.com" style="color:#1677FF;text-decoration:none;">contact@dify-hosting.com</a>. We typically respond within 24 hours.
          </p>
          <form style="display:flex;flex-direction:column;gap:1rem;" onsubmit="return false;">
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-name" style="font-size:0.875rem;font-weight:600;color:#374151;">Name</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Your name"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-email" style="font-size:0.875rem;font-weight:600;color:#374151;">Email</label>
              <input
                id="contact-email"
                type="email"
                placeholder="you@example.com"
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              />
            </div>
            <div style="display:flex;flex-direction:column;gap:0.375rem;">
              <label for="contact-message" style="font-size:0.875rem;font-weight:600;color:#374151;">Message</label>
              <textarea
                id="contact-message"
                rows="5"
                placeholder="Your message..."
                style="padding:0.625rem 0.875rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:0.9375rem;color:#111827;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit;"
                onfocus="this.style.borderColor='#1677FF'"
                onblur="this.style.borderColor='#d1d5db'"
              ></textarea>
            </div>
            <div>
              <button type="submit" class="btn-primary">Send Message</button>
            </div>
          </form>
        </div>

        <!-- Related Links -->
        <div style="padding:1.5rem;background:#f8fafc;border-radius:1rem;border:1px solid #e2e8f0;">
          <p style="font-weight:600;color:#374151;margin-bottom:0.875rem;">Explore our research:</p>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/en/best-dify-hosting/" class="btn-primary" style="text-decoration:none;">Best Dify Hosting Providers</a>
            <a href="/en/faq/" class="btn-secondary" style="text-decoration:none;">Dify FAQ</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
